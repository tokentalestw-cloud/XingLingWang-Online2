      txt.includes("召喚") || txt.includes("獻祭") || txt.includes("小旅人") ||
      txt.includes("結束") || txt.includes("對手測試") || txt.includes("防守判定") ||
      txt.includes("取消")
    ) {
      btn.style.setProperty("display", "none", "important");
    }
  });
}

