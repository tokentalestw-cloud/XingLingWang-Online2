function calculateTotalStars(isPlayer) {
  let stars = isPlayer ? playerBonusScore : enemyBonusScore;
  const zones = isPlayer ? ["player_front", "player_back"] : ["enemy_front", "enemy_back"];
  for (const zone of zones) {
    field[zone].forEach((u, i) => {
      if (u) {
        stars += getUnitStars(u, zone, i);
      }
    });
  }
  return stars;
}

function calculateUnitCount(isPlayer) {
  const zones = isPlayer ? ["player_front", "player_back"] : ["enemy_front", "enemy_back"];
  let count = 0;
  for (const zone of zones) {
    field[zone].forEach(u => {
      if (u) count++;
    });
  }
  return count;
}

