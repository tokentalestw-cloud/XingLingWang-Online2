            "【立即連動】喵女/立即效果發動！",
            "是否立刻從手牌特殊召喚一張免祭品且具「偷襲」特性的單位？（不佔用常規或戰術召喚額度）"
          );
          if (userConfirmed) {
            const extraCard = validImmediateSummons[0];
            window.XLW_bypassNormalSummonLimit = true;
            selectedHandForSummon = hand.indexOf(extraCard);
            setStatus("【立即連動】請點選我方一個空格進行特殊召喚！");
            render();
          }
        }, 300);
      }
    }
    } // end of if (!immediateEffectNegated)
    
    if (isTributeSummon) {
      playTributeSummonAnimation(zone, idx);
    }
  }

  if (isMultiplayer) {
    if (window.XLW_isFoodBallSummoning) {
      ws.send(JSON.stringify({
        action: "foodball_summon",
        zone: window.XLW_currentFoodBallZone,
        idx: window.XLW_currentFoodBallIdx,
        toZone: zone,
        toIdx: idx
      }));
    } else if (!summonMessageSent) {
      const isFromHand = (selectedHandForSummon !== "TRAVELER" &&
                          selectedHandForSummon !== "GRAVEYARD_UMBRELLA" &&
                          selectedHandForSummon !== "GRAVEYARD_WELL" &&
                          selectedHandForSummon !== "GRAVEYARD_GHOST_MEOW");
      ws.send(JSON.stringify({
        action: "summon",
        card: field[zone][idx].card,
        zone: zone,
        idx: idx,
        fromHand: isFromHand,
        tributes: window.XLW_lastTributes || []
      }));
      window.XLW_lastTributes = null;
    }
  }

  if (window.XLW_summonPlacementResolve) {
      const resolve = window.XLW_summonPlacementResolve;
      window.XLW_summonPlacementResolve = null;
      resolve();
    }
  } finally {
    const isSummoningTributeCard = (selectedTributeCard !== null && card !== null && card.id === selectedTributeCard.id);
    const keepTribute = tributeWaitingPosition && !isSummoningTributeCard;
    clearModes(keepTribute);
    render();
  }
}

