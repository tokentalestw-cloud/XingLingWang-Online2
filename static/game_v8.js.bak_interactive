function showCombatNumberAnimation(attZone, attIdx, defZone, defIdx, atkPower, defPower) {
  return new Promise((resolve) => {
    const attEl = document.querySelector(`[data-zone="${attZone}"][data-index="${attIdx}"]`);
    const defEl = document.querySelector(`[data-zone="${defZone}"][data-index="${defIdx}"]`);
    
    if (!attEl || !defEl) {
      resolve();
      return;
    }
    
    // 取得攻防格子的精準位置並計算中心點
    const attRect = attEl.getBoundingClientRect();
    const defRect = defEl.getBoundingClientRect();
    
    const midX = (attRect.left + defRect.left) / 2 + (attRect.width / 2) + window.scrollX;
    const midY = (attRect.top + defRect.top) / 2 + (attRect.height / 2) + window.scrollY;
    
    const overlay = document.createElement("div");
    overlay.className = "xlw-combat-overlay";
    overlay.style.left = `${midX}px`;
    overlay.style.top = `${midY}px`;
    
    // 標準化數值字串
    const displayAtk = (typeof atkPower === "number" || !isNaN(atkPower)) ? atkPower : atkPower;
    const displayDef = (typeof defPower === "number" || !isNaN(defPower)) ? defPower : defPower;
    
    overlay.innerHTML = `
      <div class="combat-overlay-atk">${displayAtk}</div>
      <div class="combat-overlay-vs">⚔ VS ⚔</div>
      <div class="combat-overlay-def">${displayDef}</div>
    `;
    
    document.body.appendChild(overlay);
    
    // 播放 1200 毫秒後自動移除並 resolve
    setTimeout(() => {
      overlay.remove();
      resolve();
    }, 1200);
  });
}

// 實行戰鬥判定 (防守方死亡送入對應墓地，包含卡牌碎裂火花動畫，全面支持 遠程、劇毒、偷襲、阻擋、貫穿 結算)
async function resolveUnitCombat(attZone, attIdx, defZone, defIdx, defenderOwner) {
  const attacker = field[attZone]?.[attIdx];
  const defender = field[defZone]?.[defIdx];

  if (!attacker || !defender) return "戰鬥目標不存在";

  const atkPower = getUnitAtk(attacker, attZone, attIdx);
  const defPower = getUnitAtk(defender, defZone, defIdx, true);

  // 1. 播放攻擊力對決 VS 動畫 (等待完畢)
  await showCombatNumberAnimation(attZone, attIdx, defZone, defIdx, atkPower, defPower);

  // 2. 阻擋/盾牌防禦判定
  if (window.XLW_isShieldUnit(attacker)) {
    attacker.attacking = false;
    attacker.target = null;
    return `${unitName(attacker)} 是阻擋/盾牌單位，無法發起有效進攻`;
  }
  if (window.XLW_isShieldUnit(defender)) {
    attacker.tapped = true;
    attacker.attacking = false;
    attacker.target = null;
    return `${unitName(defender)} 是阻擋/盾牌單位，本次進攻被成功阻擋`;
  }

  // 3. 讀取雙方遠程、劇毒、偷襲特性
  const attackerCard = attacker.card || attacker;
  const defenderCard = defender.card || defender;

  const attackerHasRanged = (attackerCard.keywords && attackerCard.keywords.includes("\u9060\u7a0b")) ||
                             (attackerCard.effect_text && attackerCard.effect_text.includes("\u9060\u7a0b")) ||
                             attacker.hasRanged;
  const attackerHasPoison = (attackerCard.keywords && attackerCard.keywords.includes("\u5287\u6bd2")) ||
                             (attackerCard.effect_text && attackerCard.effect_text.includes("\u5287\u6bd2")) ||
                             (attacker.equipments && attacker.equipments.includes("塗毒"));
  const attackerHasSneak = (attackerCard.keywords && attackerCard.keywords.includes("\u5077\u8972")) ||
                            (attackerCard.effect_text && attackerCard.effect_text.includes("\u5077\u8972"));

  const defenderHasPoison = (defenderCard.keywords && defenderCard.keywords.includes("\u5287\u6bd2")) ||
                             (defenderCard.effect_text && defenderCard.effect_text.includes("\u5287\u6bd2")) ||
                             (defender.equipments && defender.equipments.includes("塗毒"));

  // 4. 計算雙方是否應當被擊破 (引入 Ranged 免疫反擊與 Poisonous 必殺邏輯)
  let attackerShouldDie = false;
  let defenderShouldDie = false;

  // 基礎戰鬥數值對決 (相同攻擊力時攻擊方獲勝，防守方被破壞)
  if (atkPower >= defPower) {
    defenderShouldDie = true;
    attackerShouldDie = false;
  } else {
    attackerShouldDie = true;
    defenderShouldDie = false;
  }

  // 遠程 (Ranged) 效果應用：進攻時不會因為戰鬥失敗而被破壞（免除反擊傷害）
  if (attackerHasRanged) {
    attackerShouldDie = false;
  }

  // 劇毒 (Poisonous) 效果應用：與此單位戰鬥的單位將直接被破壞（對遠程單位的進攻無效）
  if (attackerHasPoison) {
    defenderShouldDie = true; // 劇毒進攻必殺
  }
  if (defenderHasPoison) {
    if (!attackerHasRanged) {
      attackerShouldDie = true; // 劇毒防守觸殺 (遠程進攻免疫此效果)
    }
  }

  // 5. 執行擊破與死鬥送墓
  let piercingMsg = "";
  const destPromise = [];

  const attackerIsKnightCat = (attackerCard.id === "CAT-0015" || attackerCard.id === "CAT_0015" || attackerCard.name.includes("騎士喵") ||
                               attackerCard.id === "NEU-0022" || attackerCard.id === "SSSR-NMS-0022" || attackerCard.name.includes("封印騎士"));
  const defenderIsKnightCat = (defenderCard.id === "CAT-0015" || defenderCard.id === "CAT_0015" || defenderCard.name.includes("騎士喵") ||
                               defenderCard.id === "NEU-0022" || defenderCard.id === "SSSR-NMS-0022" || defenderCard.name.includes("封印騎士"));

  // 漏食球 (SR-CAT-0053) 被動效果
  if (defenderShouldDie && (defenderCard.id === "SR-CAT-0053" || defenderCard.id === "CAT_053" || defenderCard.name.includes("漏食球"))) {
    if (!window.XLW_foodBallTriggeredTurn || window.XLW_foodBallTriggeredTurn !== turn) {
      if (defenderOwner === "enemy") {
        // 我方為進攻方，對手場上有漏食球被我方進攻，我方（進攻方）決定是否發動效果
        const hasEmpty = ["player_front", "player_back"].some(z => field[z].some(u => u === null));
        if (hasEmpty) {
          const choice = await showXLWConfirm("漏食球 效果發動", "是否召喚 1 個小旅人到我方場上以代替破壞對手的 漏食球？");
          if (isMultiplayer) {
            ws.send(JSON.stringify({
              action: "foodball_choice",
              zone: defZone,
              idx: defIdx,
              trigger: choice
            }));
          }
          if (choice) {
            defenderShouldDie = false;
            window.XLW_foodBallTriggeredTurn = turn;
            
            // 手動放置小旅人到我方場上
            window.XLW_currentFoodBallZone = defZone;
            window.XLW_currentFoodBallIdx = defIdx;
            window.XLW_isFoodBallSummoning = true;
            window.XLW_bypassNormalSummonLimit = true;
            window.XLW_bypassTurnCheck = true;
            selectedHandForSummon = "TRAVELER";
            setStatus("【漏食球 召喚】請選擇我方一個空格進行特殊召喚！");
            render();
            
            await new Promise(r => { window.XLW_summonPlacementResolve = r; });
            
            window.XLW_bypassTurnCheck = false;
            window.XLW_isFoodBallSummoning = false;
          }
        }
      } else {
        // 我方為防守方，對手(AI/敵方玩家)為進攻方，對手決定是否發動效果
        const hasEmpty = ["enemy_front", "enemy_back"].some(z => field[z].some(u => u === null));
        if (hasEmpty) {
          if (isMultiplayer) {
            // 聯網同步：等待對手傳送其漏食球效果發動決定！
            const key = `${defZone}:${defIdx}`;
            if (window.XLW_opponentFoodBallChoice[key] === undefined) {
              await new Promise(resolve => {
                const check = setInterval(() => {
                  if (window.XLW_opponentFoodBallChoice[key] !== undefined) {
                    clearInterval(check);
                    resolve();
                  }
                }, 50);
              });
            }
            const opponentTriggered = window.XLW_opponentFoodBallChoice[key];
            if (opponentTriggered) {
              defenderShouldDie = false;
              window.XLW_foodBallTriggeredTurn = turn;
              // 等對手傳送其放置位置
              if (window.XLW_opponentFoodBallSummon[key] === undefined) {
                await new Promise(resolve => {
                  const check = setInterval(() => {
                    if (window.XLW_opponentFoodBallSummon[key] !== undefined) {
                      clearInterval(check);
                      resolve();
                    }
                  }, 50);
                });
              }
              const placement = window.XLW_opponentFoodBallSummon[key];
              field[placement.zone][placement.idx] = {
                card: structuredClone(LITTLE_TRAVELER),
                tapped: false,
                attacking: false,
                target: null,
                summonedTurn: turn,
                summonedZone: placement.zone
              };
              logBattle(`漏食球 效果：對手召喚 1 個小旅人代替破壞 漏食球。`);
            }
          } else {
            // 單機 AI 模式：AI為進攻方，50% 機率發動並召喚到AI場上（我方的enemy_front/back）
            if (Math.random() < 0.5) {
              defenderShouldDie = false;
              window.XLW_foodBallTriggeredTurn = turn;
              let placed = false;
              for (const z of ["enemy_front", "enemy_back"]) {
                for (let i = 0; i < 5; i++) {
                  if (!field[z][i]) {
                    field[z][i] = {
                      card: structuredClone(LITTLE_TRAVELER),
                      tapped: false,
                      attacking: false,
                      target: null,
                      summonedTurn: turn,
                      summonedZone: z
                    };
                    logBattle(`漏食球 效果：對手召喚 1 個小旅人代替破壞 漏食球。`);
                    placed = true;
                    break;
                  }
                }
                if (placed) break;
              }
            }
          }
        }
      }
    }
  }

  // --- 二連爪擊喵 (SR-CAT-0047) 戰鬥破壞無效與攻擊力 +3 效果 ---
  if (attackerShouldDie) {
    const isDoubleClawAttacking = (attackerCard.id === "SR-CAT-0047" || attackerCard.name === "二連爪擊喵");
    if (isDoubleClawAttacking) {
      if (defenderOwner === "enemy") {
        if (!attacker.doubleClawUsed) {
          const confirmNegate = await showXLWConfirm(
            "二連爪擊喵 效果發動",
            "【二連爪擊喵】即將被戰鬥破壞！是否發動效果無效化本次破壞，並獲得 +3 攻擊力直到防守階段結束？"
          );
          if (isMultiplayer) {
            ws.send(JSON.stringify({
              action: "double_claw_choice",
              attZone: attZone,
              attIdx: attIdx,
              negate: confirmNegate
            }));
          }
          if (confirmNegate) {
            attackerShouldDie = false;
            attacker.doubleClawUsed = true;
            attacker.doubleClawBonus = true;
            attacker.atkModifier = (attacker.atkModifier || 0) + 3;
            logBattle(`✨ 效果發動：我方【二連爪擊喵】無效化了本次戰鬥破壞，並獲得 +3 攻擊力！`);
            render();
          }
        }
      } else {
        if (isMultiplayer) {
          const key = `${attZone}:${attIdx}`;
          if (window.XLW_opponentDoubleClawNegate[key] === undefined) {
            await new Promise(resolve => {
              const check = setInterval(() => {
                if (window.XLW_opponentDoubleClawNegate[key] !== undefined) {
                  clearInterval(check);
                  resolve();
                }
              }, 50);
            });
          }
          const opponentNegated = window.XLW_opponentDoubleClawNegate[key];
          if (opponentNegated) {
            attackerShouldDie = false;
            attacker.doubleClawBonus = true;
            attacker.atkModifier = (attacker.atkModifier || 0) + 3;
            logBattle(`✨ 效果發動：對手的【二連爪擊喵】無效化了本次戰鬥破壞，並獲得 +3 攻擊力！`);
            render();
          }
        } else {
          if (!attacker.doubleClawUsed) {
            attackerShouldDie = false;
            attacker.doubleClawUsed = true;
            attacker.doubleClawBonus = true;
            attacker.atkModifier = (attacker.atkModifier || 0) + 3;
            logBattle(`✨ 效果發動：對手AI的【二連爪擊喵】無效化了本次戰鬥破壞，並獲得 +3 攻擊力！`);
            render();
          }
        }
      }
    }
  }

  if (attackerShouldDie && isUnitIndestructible(attacker, attZone, attIdx, true)) {
    attackerShouldDie = false;
    logBattle(`✨ ${unitName(attacker)} 具有破壞抗性，免於被戰鬥破壞！`);
  }
  if (defenderShouldDie && isUnitIndestructible(defender, defZone, defIdx, true)) {
    defenderShouldDie = false;
    logBattle(`✨ ${unitName(defender)} 具有破壞抗性，免於被戰鬥破壞！`);
  }

  if (attackerShouldDie) {
    destPromise.push(destroyUnit(attZone, attIdx, defenderOwner === "player" ? "enemy" : "player", defenderIsKnightCat, true));
  }
  if (defenderShouldDie) {
    destPromise.push(destroyUnit(defZone, defIdx, defenderOwner, attackerIsKnightCat, true));

    // 貫穿 (Piercing) 效果判定：擊破前排後繼續進攻後排
    const hasPiercing = attacker.piercing ||
                        (attackerCard.keywords && attackerCard.keywords.includes("貫穿")) ||
                        (attackerCard.effect_text && attackerCard.effect_text.includes("貫穿")) ||
                        (attacker.equipments && attacker.equipments.some(e => e.includes("菜刀") || e.includes("迴旋飛斧")));
    if (hasPiercing && defZone.includes("front")) {
      const backZone = defZone.replace("front", "back");
      const backUnit = field[backZone]?.[defIdx];
      if (backUnit) {
        destPromise.push(destroyUnit(backZone, defIdx, defenderOwner, false, true));
        piercingMsg = `，並貫穿擊破了後排的 ${unitName(backUnit)}`;
      }
    }
  }

  if (destPromise.length > 0) {
    await Promise.all(destPromise);
  }

  // 統計與套用戰鬥成功獎勵
  const attackerSuccess = (!attackerShouldDie && defenderShouldDie);
  const defenderSuccess = (!defenderShouldDie && attackerShouldDie);
  if (attackerSuccess) {
    const successOwner = (defenderOwner === "enemy" ? "player" : "enemy");
    await applyCombatSuccessReward(attacker, defender, successOwner, true);

    if (successOwner === "player") {
      const isMeow = attacker.card && (attacker.card.deck === "喵喵賊" || attacker.card.faction === "喵喵賊" || (attacker.card.id && (String(attacker.card.id).includes("CAT") || String(attacker.card.id).includes("cat"))));
      if (isMeow) {
        window.XLW_turnCombatWins = (window.XLW_turnCombatWins || 0) + 1;
        logDebug(`【戰鬥成功追蹤】我方喵喵賊單位進攻戰鬥成功！本回合累計成功 ${window.XLW_turnCombatWins} 次。`);
        await xlwCheckDoubleClawMeowUpgrade();
      }
    }

    // --- 血戰幫狼牙棒 額外啟動效果 ---
    if (successOwner === "player") {
      const isOrc = attacker.card && (attacker.card.faction === "獸人" || attacker.card.race === "獸人" || attacker.card.id.includes("ORC") || attacker.card.id.includes("0RC"));
      const hasOtherEquip = attacker.equipments && attacker.equipments.some(eqName => {
        if (eqName === "血戰幫狼牙棒") return false;
        if (attacker.tempEquips && attacker.tempEquips[eqName] !== undefined) return false;
        if (["削弱藥水", "振奮藥水", "塗毒", "睡眠反擊拳"].some(x => eqName.includes(x))) return false;
        return true;
      });
      const maceInExtra = playerExtraDeck.find(c => c && (c.id === "R-ORC-0054" || c.name === "血戰幫狼牙棒"));

      if (isOrc && hasOtherEquip && maceInExtra) {
        const confirmAdd = await showXLWConfirm(
          "狼牙棒 效果觸發",
          `我方獸人單位 ${attacker.card.name} 進攻成功且裝備了其他裝備卡！是否將【血戰幫狼牙棒】自額外牌庫加入手牌？`,
          "是",
          "否"
        );
        if (confirmAdd) {
          playerExtraDeck.splice(playerExtraDeck.indexOf(maceInExtra), 1);
          hand.push(maceInExtra);
          logBattle(`✨ 血戰幫狼牙棒 效果：將【血戰幫狼牙棒】自額外牌庫加入我方手牌！`);
          
          if (isMultiplayer) {
            ws.send(JSON.stringify({
              action: "add_to_hand_sync"
            }));
          }
          render();
        }
      }
    }
    // ---------------------------------
  }
  if (defenderSuccess) {
    const successOwner = defenderOwner;
    await applyCombatSuccessReward(defender, attacker, successOwner, false);
  }

  // 6. 偷襲 (Sneak Attack) 效果應用：成功進攻並存活後，將此卡收回手牌
  let sneakMsg = "";
  if (attackerHasSneak && !attackerShouldDie && defenderShouldDie) {
    if (defenderOwner === "player") {
      // 攻擊方是對手
      if (isMultiplayer) {
        // 聯網同步：等待對手（進攻方）傳送其偷襲回手決定！
        const key = `${attZone}:${attIdx}`;
        if (window.XLW_opponentSneakRecall[key] === undefined) {
          await new Promise(resolve => {
            const check = setInterval(() => {
              if (window.XLW_opponentSneakRecall[key] !== undefined) {
                clearInterval(check);
                resolve();
              }
            }, 50);
          });
        }
        const opponentRecalled = window.XLW_opponentSneakRecall[key];
        if (opponentRecalled) {
          if (attacker.equipments && attacker.equipments.length > 0) {
            attacker.equipments.forEach(eqName => {
              const isTempMagic = ["削弱藥水", "振奮藥水", "塗毒", "睡眠反擊拳"].some(x => eqName.includes(x));
              if (isTempMagic) return;
              const cardObj = allCards.find(c => c && c.name === eqName) || { name: eqName, type: "magic" };
              const cloned = structuredClone(cardObj);
              cloned.type = "magic";
              window.XLW_ENEMY.grave.push(cloned);
              enemyGraveyard = window.XLW_ENEMY.grave;
              logBattle(`✨ 裝備卡 ${cloned.name} 因對手單位回手進入對手墓地。`);
            });
            attacker.equipments = [];
          }
          if (window.XLW_ENEMY.hand) {
            window.XLW_ENEMY.hand.push(attacker.card);
          }
          field[attZone][attIdx] = null;
          sneakMsg = `，且對手觸發「偷襲」成功收回其手牌`;
        } else {
          attacker.tapped = true;
          attacker.attacking = false;
          attacker.target = null;
          sneakMsg = `，對手選擇放棄「偷襲」回手，使該單位留在場上處於疲勞狀態`;
        }
      } else {
        if (attacker.equipments && attacker.equipments.length > 0) {
          attacker.equipments.forEach(eqName => {
            const isTempMagic = ["削弱藥水", "振奮藥水", "塗毒", "睡眠反擊拳"].some(x => eqName.includes(x));
            if (isTempMagic) return;
            const cardObj = allCards.find(c => c && c.name === eqName) || { name: eqName, type: "magic" };
            const cloned = structuredClone(cardObj);
            cloned.type = "magic";
            window.XLW_ENEMY.grave.push(cloned);
            enemyGraveyard = window.XLW_ENEMY.grave;
            logBattle(`✨ 裝備卡 ${cloned.name} 因對手單位回手進入對手墓地。`);
          });
          attacker.equipments = [];
        }
        if (window.XLW_ENEMY.hand) {
          window.XLW_ENEMY.hand.push(attacker.card);
          field[attZone][attIdx] = null;
          sneakMsg = `，且對手觸發「偷襲」成功收回其手牌`;
        }
      }
    } else {
      // 攻擊方是我方：彈出奢華確認框讓玩家自行選擇是否回手！
      const userWantsRecall = await showXLWConfirm(
        "🥷 偵測到【偷襲】契機！",
        `我方單位 <b>${unitName(attacker)}</b> 進攻成功！<br>是否啟動「偷襲」將其收回手牌並觸發偷襲成功連動效果？`,
        "確認回手 (啟動偷襲)",
        "留在場上 (放棄回手)"
      );
      
      if (isMultiplayer) {
        ws.send(JSON.stringify({
          action: "sneak_recall",
          attZone: attZone,
          attIdx: attIdx,
          recall: userWantsRecall
        }));
      }
      
      if (userWantsRecall) {
        if (attacker.equipments && attacker.equipments.length > 0) {
          attacker.equipments.forEach(eqName => {
            const cardObj = allCards.find(c => c && c.name === eqName) || { name: eqName, type: "magic" };
            const cloned = structuredClone(cardObj);
            cloned.type = "magic";
            graveyard.push(cloned);
            logBattle(`✨ 裝備卡 ${cloned.name} 因我方單位回手進入我方墓地。`);
          });
          attacker.equipments = [];
        }
        hand.push(attacker.card);
        field[attZone][attIdx] = null;
        sneakMsg = `，且觸發「偷襲」成功收回我方手牌`;
        
        // 核心：觸發「偷襲成功」的一系列效果！
        await triggerSneakAttackSuccessEffects(attacker.card);
      } else {
        // 放棄回手，留在場上並處於疲勞狀態
        attacker.tapped = true;
        attacker.attacking = false;
        attacker.target = null;
        sneakMsg = `，我方選擇放棄「偷襲」回手，使該單位留在場上處於疲勞狀態`;

        // 負能量喵 (R-CAT-0046) 效果
        const hasNegativeMeow = ["player_front", "player_back"].some(zone => 
          field[zone].some(u => u && (u.card?.id === "R-CAT-0046" || u.card?.name === "負能量喵"))
        );
        const isMeowCard = (c) => c && (c.deck === "喵喵賊" || c.faction === "喵喵賊" || (c.id && (String(c.id).includes("CAT") || String(c.id).includes("cat"))));
        
        if (hasNegativeMeow && isMeowCard(attacker.card)) {
          logBattle(`✨【負能量喵】效果：我方喵喵賊單位 ${attacker.card.name} 進攻成功且未回手，視為偷襲成功 2 次！`);
          await triggerSneakAttackSuccessEffects(attacker.card);
          await triggerSneakAttackSuccessEffects(attacker.card);
        }
      }
    }
  } else {
    // 未回手之存活單位進行橫置 Tap 鎖定
    if (!attackerShouldDie) {
      attacker.tapped = true;
      attacker.attacking = false;
      attacker.target = null;
    }
  }

  // 7. 回傳詳細戰鬥日誌
  let combatMsg = "";
  if (attackerShouldDie && defenderShouldDie) {
    combatMsg = `${unitName(attacker)} 與 ${unitName(defender)} 實力相當或劇毒互噬，同歸於盡`;
  } else if (attackerShouldDie) {
    combatMsg = `${unitName(attacker)} 攻擊失敗，自身被破壞，而 ${unitName(defender)} 完好無損`;
  } else if (defenderShouldDie) {
    combatMsg = `${unitName(attacker)} 成功擊破了 ${unitName(defender)}${piercingMsg}${sneakMsg}`;
  } else {
    combatMsg = `${unitName(attacker)} 進攻了 ${unitName(defender)}，雙方皆安然無恙${sneakMsg}`;
  }

  // 武士繪 (R-VLG-0011) 戰鬥成功回收效果
  if (!attackerShouldDie && defenderShouldDie && defenderOwner === "enemy") {
    if (attacker.card && attacker.card.name.includes("武士繪")) {
      const yokaiInGrave = graveyard.filter(c => c && c.type === "unit" && (c.faction === "妖怪村莊" || c.id?.includes("VLG")));
      if (yokaiInGrave.length > 0) {
        setTimeout(async () => {
          const choices = yokaiInGrave.map((c, i) => ({ text: `${c.name} (${c.id})`, value: i }));
          const chosen = await showXLWChoiceModal("武士繪 戰鬥成功效果", "請選擇一張墓地中的妖怪村莊單位回收至手牌：", choices);
          if (chosen !== null && chosen !== undefined) {
            const cardToRecover = yokaiInGrave[chosen];
            const graveIdx = graveyard.indexOf(cardToRecover);
            if (graveIdx >= 0) {
              graveyard.splice(graveIdx, 1);
              hand.push(cardToRecover);
              logBattle(`武士繪 效果：成功回收墓地中的 ${cardToRecover.name} 至手牌。`);
              render();
            }
          }
        }, 100);
      }
    }
  }

  return combatMsg;
}

// 帶有碎裂和火花粒子特效的卡牌銷毀函數
// ===== 藝術品 (藝術品) 輔助屬性與觸發判定 =====

function isLastCard(c) {
  if (!c) return false;
  return (c.keywords && c.keywords.includes("最後的")) ||
         (c.effect_text && c.effect_text.includes("最後的")) ||
         (c.effect && c.effect.includes("最後的")) ||
         (c.art_subtype === "最後的") ||
         (c.name?.includes("最後的"));
}

function canSummonCard(card, isPlayer) {
  if (!card) return false;
  if (card.id === "SR-ART-0026" || card.name?.includes("和平使者 耶叔")) {
    const backZone = isPlayer ? "player_back" : "enemy_back";
    let lastCount = 0;
    if (field[backZone]) {
      field[backZone].forEach(u => {
        if (u && u.card) {
          if (isLastCard(u.card)) lastCount++;
        }
      });
    }
    const ok = lastCount >= 3;
    if (!ok && isPlayer) {
      setStatus(`【召喚限制】${card.name} 需要我方後排有 3 個或以上的「最後的」單位！`);
    }
    return ok;
  }
  if (card.id === "SR-ART-0059" || card.id === "ASSR-ART-0059" || card.name === "始皇帝") {
    const zones = isPlayer ? ["player_front", "player_back"] : ["enemy_front", "enemy_back"];
    let anyTapped = false;
    for (const z of zones) {
      if (field[z]) {
        for (const u of field[z]) {
          if (u && u.tapped) {
            anyTapped = true;
            break;
          }
        }
      }
      if (anyTapped) break;
    }
    if (anyTapped) {
      if (isPlayer) {
        setStatus(`【召喚限制】${card.name} 打出前，我方場上所有單位必須皆未橫置！`);
      }
      return false;
    }
  }
  return true;
}

function isUnitIndestructible(unit, zone, idx, isCombatDestruction = false) {
  if (!unit || !unit.card) return false;
  if (unit.indestructible) return true;
  const c = unit.card;
  
  // 最後的早餐 (R-ART-0030) 永久戰鬥破壞抗性
  if ((c.id === "R-ART-0030" || c.name?.includes("最後的早餐")) && isCombatDestruction) return true;

  // 三腳鼎 (C-ART-0061) 破壞抗性
  if (c.id === "C-ART-0061" || c.name?.includes("三腳鼎")) return true;
  
  // 萌娜麗莎的大笑 (R-ART-0001) 橫置時不會被破壞
  if ((c.id === "R-ART-0001" || c.name?.includes("萌娜麗莎")) && unit.tapped) return true;

  // 梵老爹 (ART-0009) 破壞抗性
  if (c.id === "ART-0009" || c.name?.includes("梵老爹")) return true;
  
  // 番茄之子 (ART-0015) 橫放時不會被破壞
  if ((c.id === "ART-0015" || c.name?.includes("番茄之子")) && unit.tapped) return true;
  
  // 頸部痠痛的女人 (R-ART-0012) 橫放時被賦予破壞抗性
  if ((c.id === "R-ART-0012" || c.name?.includes("頸部痠痛的女人")) && unit.tapped) return true;
  
  // 哭泣女人 (R-ART-0042) 橫放時被賦予破壞抗性
  if ((c.id === "R-ART-0042" || c.name?.includes("哭泣女人")) && unit.tapped) return true;
  
  return false;
}

function isUnitMagicImmune(unit) {
  if (!unit || !unit.card) return false;
  if (unit.magicImmune) return true;
  if (unit.magicImmuneUntilTurn && unit.magicImmuneUntilTurn >= turn) return true;
  
  const c = unit.card;
  const isArtMagicImmune = c.id === "ART-0005" || c.name?.includes("鎧甲擺件") ||
                           c.id === "ART-0009" || c.name?.includes("梵老爹") ||
                           c.id === "ART-0015" || c.name?.includes("番茄之子") ||
                           c.id === "ART-0016" || c.name?.includes("摩艾石巨像") ||
                           c.id === "R-ART-0001" || c.name?.includes("萌娜麗莎") ||
                           c.id === "SR-ART-0026" || c.name?.includes("和平使者 耶叔") ||
                           c.id === "R-ART-0012" || c.name?.includes("頸部痠痛的女人") ||
                           c.id === "R-ART-0038" || c.name?.includes("金衣服的女人") ||
                           c.id === "R-ART-0042" || c.name?.includes("哭泣女人") ||
                           c.id === "SR-ART-0059" || c.id === "ASSR-ART-0059" || c.name?.includes("始皇帝") ||
                           c.id === "C-ART-0060" || c.name?.includes("戰士陶俑") ||
                           c.id === "R-ART-0046" || c.name?.includes("牆壁上的塗鴉");
  if (isArtMagicImmune) return true;
  
  return false;
}

function isPigmentCard(card) {
  if (!card) return false;
  const name = card.name || "";
  const keywords = card.keywords || [];
  const keywordStr = Array.isArray(keywords) ? keywords.join(",") : String(keywords);
  const subtype = card.art_subtype || "";
  return name.includes("顏料") || name.includes("畫家") || subtype.includes("顏料") || keywordStr.includes("顏料") ||
         card.id === "R-ART-0022" || card.id === "R-ART-0023" || card.id === "R-ART-0024" || card.id === "R-ART-0045" || card.id === "R-ART-0046";
}

function hasPigmentArtistOnField(side) {
  const zones = side === "player" ? ["player_front", "player_back"] : ["enemy_front", "enemy_back"];
  for (const z of zones) {
    for (let i = 0; i < 5; i++) {
      const u = field[z][i];
      if (u && u.card && (u.card.id === "R-ART-0049" || u.card.id === "SSR-ART-0049" || u.card.name?.includes("顏料藝術家"))) {
        return true;
      }
    }
  }
  return false;
}

function hasOtherPigmentsInGrave(side) {
  const list = side === "player" ? graveyard : (window.XLW_ENEMY?.grave || enemyGraveyard || []);
  return list.some(c => c && isPigmentCard(c));
}

function hasOtherPigmentsOnField(side, excludeIdx, excludeZone) {
  const zones = side === "player" ? ["player_front", "player_back"] : ["enemy_front", "enemy_back"];
  for (const z of zones) {
    for (let i = 0; i < 5; i++) {
      if (z === excludeZone && i === excludeIdx) continue;
      const u = field[z][i];
      if (u && u.card && isPigmentCard(u.card)) {
        return true;
      }
    }
  }
  return false;
}

function hasOtherPigmentsInHand(side) {
  if (side === "player") {
    return hand.some(c => c && isPigmentCard(c));
  } else {
    const oppHand = window.XLW_ENEMY?.hand || [];
    return oppHand.some(c => c && isPigmentCard(c));
  }
}

function getCardTributeCost(card) {
  if (!card) return 0;
  let trib = Number(card.tribute || 0);
  const isArt = card.faction === "藝術品" || card.id?.includes("ART") || card.race?.includes("藝術品");
  if (isArt && window.XLW_artFrameBuffActiveTurn === turn) {
    trib = Math.max(0, trib - 1);
  }
  return trib;
}

function countSelectedTributesValue(tributesList, targetCard) {
  let value = 0;
  const isArt = targetCard && (targetCard.faction === "藝術品" || targetCard.id?.includes("ART") || targetCard.race?.includes("藝術品"));
  tributesList.forEach(t => {
    if (t.zone === "dummy") {
      value += 1;
      return;
    }
    const unit = field[t.zone][t.idx];
    if (unit && unit.card) {
      const card = unit.card;
      const isTappedPearl = (card.id === "ART-0008" || card.name?.includes("珍珠少女")) && unit.tapped;
      if (isArt) {
        if (isTappedPearl) {
          value += 2;
        } else {
          const side = t.zone.startsWith("player_") ? "player" : "enemy";
          const hasArtist = hasPigmentArtistOnField(side);
          let extraTribute = 1;
          
          if (card.id === "R-ART-0022" || card.name?.includes("紅色顏料")) {
            if (hasOtherPigmentsInGrave(side)) {
              extraTribute = hasArtist ? 3 : 2;
            }
          } else if (card.id === "R-ART-0023" || card.name?.includes("綠色顏料")) {
            if (hasOtherPigmentsOnField(side, t.idx, t.zone)) {
              extraTribute = hasArtist ? 3 : 2;
            }
          } else if (card.id === "R-ART-0024" || card.name?.includes("藍色顏料")) {
            if (hasOtherPigmentsInHand(side)) {
              extraTribute = hasArtist ? 3 : 2;
            }
          }
          value += extraTribute;
        }
      } else {
        value += 1;
      }
    } else {
      value += 1;
    }
  });
  return value;
}

async function triggerAiSummonEffects(card, destZone, destIdx) {
  if (!card) return;
  
  if (card.name?.includes("兩位陌生人") || card.id === "ART-0007") {
    let target = null;
    for (const z of ["player_front", "player_back"]) {
      for (let i = 0; i < 5; i++) {
        const u = field[z][i];
