function xlwCleanExpiredTempEquips(currentTurn) {
  for (const zone of ["player_front", "player_back", "enemy_front", "enemy_back"]) {
    for (let i = 0; i < 5; i++) {
      const u = field[zone][i];
      if (u && u.equipments && u.tempEquips) {
        let changed = false;
        const keysToDelete = [];
        for (const eqName in u.tempEquips) {
          if (u.tempEquips[eqName] <= currentTurn) {
            keysToDelete.push(eqName);
          }
        }
        if (keysToDelete.length > 0) {
          keysToDelete.forEach(eqName => {
            u.equipments = u.equipments.filter(x => x !== eqName);
            delete u.tempEquips[eqName];
            logBattle(`✨ ${eqName} 的時效已到，該效果從 ${u.card?.name || "單位"} 身上消失。`);
          });
          changed = true;
        }
        if (changed) {
          if (u.equipments.length === 0) {
            delete u.equipments;
          }
        }
      }
    }
  }
  render();
}

