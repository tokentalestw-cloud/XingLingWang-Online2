// 通用戰鬥成功獎勵處理
async function applyCombatSuccessReward(unit, oppUnit, owner, isAttacker) {
  if (!unit || !unit.card || !oppUnit) return;
  const card = unit.card;
  const isPlayer = owner === "player";
  
  let baseReward = 0;
  let hasRewardEffect = false;
  const cid = card.id;
  const name = card.name;
  
  if ((cid === "R-ORC-0015" || name?.includes("獸人弓箭手")) && isAttacker) {
    baseReward += 2;
    hasRewardEffect = true;
  }
  if (cid === "R-ORC-0029" || name?.includes("符咒獸人")) {
    baseReward += 1;
    hasRewardEffect = true;
  }
  if ((cid === "R-ROC-0040" || cid === "R-ORC-0040" || name?.includes("嗜血獸人")) && isAttacker) {
    baseReward += 3;
    hasRewardEffect = true;
  }
  if (unit.steakBonus && isAttacker) {
    baseReward += 5;
    hasRewardEffect = true;
  }
  if ((cid === "ORC-0005" || name?.includes("突擊獸人")) && isAttacker) {
    baseReward += 2;
    hasRewardEffect = true;
  }
  if (cid === "R-ORC-0031" || name?.includes("躺平獸人")) {
    baseReward += 2;
    hasRewardEffect = true;
  }
  if ((cid === "ORC-0008" || name?.includes("雷哥")) && isAttacker) {
    baseReward += 1;
    hasRewardEffect = true;
  }
  if (cid === "SR-ORC-0052" || name?.includes("獸人爺爺")) {
    baseReward += 2;
    hasRewardEffect = true;
  }
  if (cid === "SSR-ORC-0057" || name?.includes("禁衛軍獸人")) {
    baseReward += 2;
    hasRewardEffect = true;
  }
  
  if (hasRewardEffect && ((isPlayer && window.XLW_debbieActive) || (!isPlayer && window.XLW_enemyDebbieActive))) {
    baseReward += 1;
    logBattle(`✨ 委託者 戴比 被動：使該單位的戰鬥成功獎勵額外 +1★！`);
  }
  
  if (baseReward > 0) {
    if (isPlayer) {
      playerBonusScore += baseReward;
      logBattle(`✨ ${card.name} 戰鬥成功：我方額外獲得 +${baseReward}★ 獎勵！`);
    } else {
      enemyBonusScore += baseReward;
      logBattle(`✨ 對手 ${card.name} 戰鬥成功：對手額外獲得 +${baseReward}★ 獎勵！`);
    }
    renderScore();
  }

  // 尿尿小男童 (ART-0017) 戰鬥成功召喚旅人效果
  if ((cid === "ART-0017" || name?.includes("尿尿小男童")) && isAttacker) {
    if (isPlayer) {
      logBattle(`✨ 尿尿小男童 效果：進攻成功，準備召喚 1 個小旅人！`);
      let emptySlots = [];
      for (const z of ["player_front", "player_back"]) {
        for (let i = 0; i < 5; i++) {
          if (!field[z][i]) emptySlots.push({ zone: z, idx: i });
        }
      }
      if (emptySlots.length > 0) {
        const target = emptySlots.find(s => s.zone === "player_front") || emptySlots[0];
        field[target.zone][target.idx] = {
          card: structuredClone(LITTLE_TRAVELER),
          tapped: false,
          attacking: false,
          target: null,
          summonedTurn: turn,
          summonedZone: target.zone
        };
        logBattle(`✨ 尿尿小男童 效果：在我方 ${target.zone.includes("front") ? "前排" : "後排"}${target.idx + 1} 召喚了小旅人。`);
        playTravelerSummonAnimation("#playerForest", target.zone, target.idx);
        if (isMultiplayer) {
          ws.send(JSON.stringify({
            action: "debbie_summon_single",
            zone: target.zone,
            idx: target.idx
          }));
        }
      } else {
        logBattle("尿尿小男童 效果：我方場上已滿，無法召喚小旅人。");
      }
    } else {
      logBattle(`✨ 對手 尿尿小男童 效果：進攻成功，對手召喚了 1 個小旅人！`);
      let emptySlots = [];
      for (const z of ["enemy_front", "enemy_back"]) {
        for (let i = 0; i < 5; i++) {
          if (!field[z][i]) emptySlots.push({ zone: z, idx: i });
        }
      }
      if (emptySlots.length > 0) {
        const target = emptySlots.find(s => s.zone === "enemy_front") || emptySlots[0];
        field[target.zone][target.idx] = {
          card: structuredClone(LITTLE_TRAVELER),
          tapped: false,
          attacking: false,
          target: null,
          summonedTurn: turn,
          summonedZone: target.zone
        };
        logBattle(`✨ 對手 尿尿小男童 效果：在對手 ${target.zone.includes("front") ? "前排" : "後排"}${target.idx + 1} 召喚了小旅人。`);
        playTravelerSummonAnimation("#enemyForest", target.zone, target.idx);
      }
    }
  }
  
  // 獸人粉絲被動效果
  const isOrc = card.faction === "獸人" || card.race === "獸人" || card.id.includes("ORC") || card.id.includes("0RC");
  if (isOrc) {
    const targetZones = isPlayer ? ["player_front", "player_back"] : ["enemy_front", "enemy_back"];
    let hasFans = false;
    for (const z of targetZones) {
      if (field[z].some(u => u && (u.card?.id === "R-ORC-0051" || u.card?.name?.includes("獸人粉絲")))) {
        hasFans = true;
      }
    }
    
    if (hasFans) {
      const myAtk = getUnitAtk(unit);
      const oppAtk = getUnitAtk(oppUnit);
      if (myAtk - oppAtk >= 3) {
        if (isPlayer) {
          playerBonusScore += 2;
          logBattle(`✨ 獸人粉絲 被動：獸人單位 ${card.name} 戰鬥成功且攻擊力超出對方 3 點以上，我方獲得 +2★ 獎勵！`);
        } else {
          enemyBonusScore += 2;
          logBattle(`✨ 獸人粉絲 被動：對手獸人單位 ${card.name} 戰鬥成功且攻擊力超出我方 3 點以上，對手獲得 +2★ 獎勵！`);
        }
        renderScore();
      }
    }
  }
}

