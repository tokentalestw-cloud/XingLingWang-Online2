          const isImmune = u.card && (u.card.id === "SR-ART-0026" || u.card.name?.includes("和平使者 耶叔") || u.card.name?.includes("天狗") || u.card.id === "R-ART-0046" || u.card.name?.includes("牆壁上的塗鴉"));
          if (!isImmune) {
