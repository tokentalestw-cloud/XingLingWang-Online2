                logBattle(`✨ 迴旋飛斧 效果：${obj.card.name} 獲得貫穿效果與最終攻擊力加倍！`);
              }
              else if (spellCard.name?.includes("狼牙棒") || spellCard.id === "R-ORC-0054") {
