    }
  }
  else if (card.id === "R-ART-0032" || card.id === "ART-0032" || card.name?.includes("實習畫家")) {
    const pigmentInEnemyDeck = window.XLW_ENEMY.deck.filter(c => c && c.type === "unit" && isPigmentCard(c));
