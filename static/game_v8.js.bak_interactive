function shuffle(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
}

function draw(n) {
  const deckName = $("deckSelect") ? $("deckSelect").value : "喵喵賊";
  for (let i = 0; i < n; i++) {
    if (deck.length === 0) {
      setStatus("牌庫已空。");
      break;
    }
    const c = deck.pop();
    if (c) {
      hand.push(c);
    }
  }
}

