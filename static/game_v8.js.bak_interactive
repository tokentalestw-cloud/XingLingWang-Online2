async function xlwCheckDefenderGuardEffect() {
  if (window.XLW_defenderGuardUsedTurn === turn) return; // 本回合已使用過

  // 1. 尋找我方場上的「禁衛軍獸人」單位
  let guards = [];
  for (const z of ["player_front", "player_back"]) {
    for (let i = 0; i < 5; i++) {
      const u = field[z][i];
      if (u && (u.card?.id === "SSR-ORC-0057" || u.card?.name?.includes("禁衛軍獸人"))) {
        guards.push({ zone: z, idx: i, unit: u });
      }
    }
  }

  if (guards.length === 0) return; // 場上沒有禁衛軍獸人

  // 2. 尋找所有進攻目標不是這些禁衛軍獸人的敵方進攻單位
  let attackingEnemyUnits = [];
  for (const ez of ["enemy_front", "enemy_back"]) {
    for (let i = 0; i < 5; i++) {
      const enemyUnit = field[ez][i];
      if (enemyUnit && enemyUnit.attacking && enemyUnit.target) {
        const isTargetingAGuard = guards.some(g => enemyUnit.target.zone === g.zone && enemyUnit.target.idx === g.idx);
        if (!isTargetingAGuard) {
          attackingEnemyUnits.push({ zone: ez, idx: i, unit: enemyUnit });
        }
      }
    }
  }

  if (attackingEnemyUnits.length === 0) return; // 沒有可轉移的目標

  // 3. 詢問是否發動效果
  const confirmUse = await showXLWConfirm("禁衛軍獸人 效果發動", "我方場上有禁衛軍獸人，是否發動其能力使一個敵方單位的攻擊目標改為攻擊該禁衛軍獸人？");
  if (!confirmUse) return;

  // 4. 若有多個禁衛軍獸人，選擇要讓哪一個防守
  let chosenGuard = guards[0];
  if (guards.length > 1) {
    const guardChoices = guards.map((g, i) => ({ text: `我方 ${g.zone.includes("front") ? "前排" : "後排"}${g.idx + 1}`, value: i }));
    const chosenGuardIdx = await showXLWChoiceModal("選擇防守的禁衛軍獸人", "選擇我方禁衛軍獸人：", guardChoices);
    if (chosenGuardIdx === null || chosenGuardIdx === undefined) return;
    chosenGuard = guards[chosenGuardIdx];
  }

  // 5. 選擇欲轉移目標的敵方單位
  const enemyChoices = attackingEnemyUnits.map((u, i) => ({
    text: `${u.unit.card.name} (原目標: ${u.unit.target.zone.includes("front") ? "前排" : "後排"}${u.unit.target.idx + 1})`,
    value: i
  }));
  const chosenEnemyIdx = await showXLWChoiceModal("選擇欲轉移目標的敵方單位", "選擇敵方進攻單位：", enemyChoices);
  if (chosenEnemyIdx === null || chosenEnemyIdx === undefined) return;

  const targetEnemy = attackingEnemyUnits[chosenEnemyIdx];

  // 6. 更新本地狀態
  targetEnemy.unit.target = { zone: chosenGuard.zone, idx: chosenGuard.idx, redirected: true };
  window.XLW_defenderGuardUsedTurn = turn;
  logBattle(`✨ 禁衛軍獸人 效果：使對手 ${targetEnemy.unit.card.name} 的攻擊目標轉移為我方的 禁衛軍獸人！`);

  // 7. 聯網同步
  if (isMultiplayer) {
    ws.send(JSON.stringify({
      action: "redirect_attack_target",
      attZone: targetEnemy.zone,
      attIdx: targetEnemy.idx,
      zone: chosenGuard.zone,
      idx: chosenGuard.idx
    }));
  }

  render();
}

async function xlwResolvePlayerDefensePhase() {
  if (window.XLW_DEFENSE_RULE.resolving) return;
  window.XLW_DEFENSE_RULE.resolving = true;

  try {
    // 在結算開始前，檢查禁衛軍獸人的效果發動
    await xlwCheckDefenderGuardEffect();

    // 聯網同步：開始防守階段
    if (isMultiplayer) {
      ws.send(JSON.stringify({ action: "start_defense_phase" }));
    }

    logBattle("—— 我方防守階段開始 (依戰線 1 -> 5 詢問並結算) ——");
    setStatus("我方防守判定，系統正在依序結算各星星戰線戰鬥...");

    for (let lane = 0; lane < 5; lane++) {
      let attacker = null;
      let attZone = "";
      if (field.enemy_front[lane] && field.enemy_front[lane].attacking) {
        attacker = field.enemy_front[lane];
        attZone = "enemy_front";
      } else if (field.enemy_back[lane] && field.enemy_back[lane].attacking) {
        attacker = field.enemy_back[lane];
        attZone = "enemy_back";
      }

      if (!attacker) {
        if (isMultiplayer) {
          ws.send(JSON.stringify({ action: "resolve_lane", lane: lane }));
        }
        setStatus(`防守判定：星星戰線 ${lane + 1} 對手無進攻。`);
        await sleep(650);
        continue;
      }

      // 詢問玩家是否要在這條戰線發動防守反制魔法
      const wantCounter = await showXLWConfirm(
        `戰線 ${lane + 1} 魔法反制`,
        `對手在星星戰線 ${lane + 1} 的 ${attacker.card.name} 發動了進攻，是否在此戰線戰鬥前發動防守反制魔法卡（如削弱藥水等）？`,
        "是",
        "否"
      );
      if (wantCounter) {
        window.XLW_defenseCounterActive = true;
        setStatus(`戰線 ${lane + 1} 反制中：您可以從手牌中打出魔法卡。完成後請點擊右下角「結束反制並開始戰鬥結算」按鈕。`);
        logBattle(`我方選擇在星星戰線 ${lane + 1} 進行防守階段魔法反制。`);
        render();
        await new Promise(resolve => {
          window.XLW_defenseCounterResolve = resolve;
        });
        window.XLW_defenseCounterActive = false;
        render();
      } else {
        logBattle(`我方選擇不對星星戰線 ${lane + 1} 進行防守階段魔法反制。`);
      }

      // 聯網同步：通知對手結算此戰線
      if (isMultiplayer) {
        ws.send(JSON.stringify({ action: "resolve_lane", lane: lane }));
      }

      // 規則九第4條：進攻單位將以其前方第一個敵方單位為進攻目標，並將其視為防守單位
      let defZone = "";
      let defender = null;
      let defIdx = lane;

      if (attacker.target && attacker.target.redirected) {
        defZone = attacker.target.zone;
        defIdx = attacker.target.idx;
        defender = field[defZone][defIdx];
      } else {
        if (field.player_front[lane]) {
          defender = field.player_front[lane];
          defZone = "player_front";
        } else if (field.player_back[lane]) {
          defender = field.player_back[lane];
          defZone = "player_back";
        }
      }

      // 規則九第2條：前方沒有敵方單位時，橫置單位維持橫置，不立直
      if (!defender) {
        attacker.attacking = false;
        attacker.target = null;
        attacker.tapped = true; // 橫置單位維持橫置，不立直
        logBattle(`防守判定：星星戰線 ${lane + 1} 前方無我方單位，對手進攻單位進行空戰線結算（陣營維持橫置）。`);
        setStatus(`防守判定：星星戰線 ${lane + 1} 前方無我方單位，對手進攻單位已橫置。`);
        render();
        await sleep(650);
        continue;
      }

      // 動態更新進攻目標
      if (!attacker.target || !attacker.target.redirected) {
        attacker.target = { zone: defZone, idx: defIdx };
      }

      if (window.XLW_isShieldUnit(defender)) {
        attacker.tapped = true;
        attacker.attacking = false;
        attacker.target = null;
        setStatus(`防守判定：星星戰線 ${lane + 1} 被盾牌阻擋。`);
        render();
        await sleep(650);
        continue;
      }

      setStatus(`對決！星星戰線 ${lane + 1}：${unitName(attacker)} ⚔ ${unitName(defender)}`);
      flashBattle(attZone, lane, defZone, defIdx);
      await sleep(650);

      const resultMsg = await resolveUnitCombat(attZone, lane, defZone, defIdx, "player");
      logBattle(`防守對決：${resultMsg}`);
      setStatus(`戰線 ${lane + 1} 結果：${resultMsg}`);
      render();
      await sleep(750);
    }
  } catch (err) {
    console.error("我方防守對決出錯:", err);
    logBattle(`我方防守出錯: ${err.message}`);
  } finally {
    window.XLW_DEFENSE_RULE.playerNeedsDefense = false;
    window.XLW_DEFENSE_RULE.resolving = false;
    
    xlwCleanDoubleClawBonus();
    phase = "召喚階段";
    logBattle("—— 我方防守階段結束，進入召喚階段 ——");
    setStatus("防守階段結算完成！已進入「召喚階段」，您可以開始召喚單位。");
    render();
    await xlwCheckBananaMarquisMovement(true);
    checkCallGameAtTurnStart(true);
    if (isMultiplayer) {
      sendFullGameStateToOpponent();
    }
  }
}


