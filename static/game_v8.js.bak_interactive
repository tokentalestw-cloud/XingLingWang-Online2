            break;
          }
        }
      }
      if (target) break;
    }
    if (target) {
      field[target.zone][target.idx].tapped = true;
      logBattle(`✨ 兩位陌生人 效果：對手使我方 ${field[target.zone][target.idx].card.name} 橫放！`);
