function promptNextChainAction() {
  const overlay = getOrCreateSpellChainOverlay();
  const statusText = document.getElementById("xlw-chain-status");
  const actionsDiv = document.getElementById("xlw-chain-actions");
  actionsDiv.innerHTML = "";

  if (window.XLW_chainAutoPassTimeout) {
    clearTimeout(window.XLW_chainAutoPassTimeout);
    window.XLW_chainAutoPassTimeout = null;
  }

  const lastItem = spellChainStack[spellChainStack.length - 1];
  
  // Who is the next responder?
  if (lastItem.owner === "me") {
    statusText.textContent = "⌛ 等待對手確認是否進行連鎖反制...";
  } else {
    // I am the responder.
    // 魔法炸彈客是單位卡，不能被可以克制魔法卡的卡片（魔法反制、終極無效化等）所克制
    const isLastItemUnit = lastItem.card.type === "unit" || lastItem.card.name.includes("魔法炸彈客") || lastItem.card.id === "NEU-0025";
    const counterCards = isLastItemUnit ? [] : hand.filter(c => c && (
      c.name.includes("魔法反制") || 
      c.name.includes("終極無效化") || 
      c.name.includes("法術解析") || 
      c.name.includes("法術保護") ||
      c.name.includes("魔法炸彈客") ||
      c.id === "NEU-0025"
    ));

    if (counterCards.length > 0) {
      statusText.textContent = `🔥 對手連鎖發動了 ${lastItem.card.name}，是否進行連鎖反制？`;
      
      // Pass button
      const passBtn = document.createElement("button");
      passBtn.className = "forest-summon-btn";
      passBtn.style.background = "#ff4d4f";
      passBtn.style.color = "#fff";
      passBtn.style.borderColor = "#ff4d4f";
      passBtn.style.padding = "8px 20px";
      passBtn.style.fontSize = "14px";
      passBtn.style.height = "auto";
      passBtn.style.cursor = "pointer";
      passBtn.style.boxShadow = "0 4px 10px rgba(0,0,0,0.5)";
      passBtn.textContent = "❌ 不進行反制 (Pass)";
      passBtn.onclick = () => {
        actionsDiv.innerHTML = "";
        statusText.textContent = "⌛ 正在送出連鎖決議...";
        ws.send(JSON.stringify({ action: "spell_chain_resolve" }));
        resolveLocalSpellChain();
      };
      actionsDiv.appendChild(passBtn);

      // Counter buttons
      counterCards.forEach(c => {
        const counterBtn = document.createElement("button");
        counterBtn.className = "forest-summon-btn";
        counterBtn.style.background = "#52c41a";
        counterBtn.style.color = "#fff";
        counterBtn.style.borderColor = "#52c41a";
        counterBtn.style.padding = "8px 20px";
        counterBtn.style.fontSize = "14px";
        counterBtn.style.height = "auto";
        counterBtn.style.cursor = "pointer";
        counterBtn.style.boxShadow = "0 4px 10px rgba(0,0,0,0.5)";
        counterBtn.textContent = `🔥 使用 ${c.name}`;
        counterBtn.onclick = () => {
          actionsDiv.innerHTML = "";
          statusText.textContent = `🔥 正在連鎖施放 ${c.name}...`;
          
          // Remove from hand
          hand.splice(hand.indexOf(c), 1);
          
          // Add to local stack
          spellChainStack.push({ card: c, owner: "me" });
          
          // Sync with opponent
          ws.send(JSON.stringify({
            action: "spell_chain_add",
            card: c
          }));
          
          // Update UI
          showSpellChainUI(spellChainStack);
          promptNextChainAction();
          render();
        };
        actionsDiv.appendChild(counterBtn);
      });
    } else {
      statusText.textContent = "❌ 我方手牌中無可用反制魔法卡，將自動放行...";
      
      const autoPassBtn = document.createElement("button");
      autoPassBtn.className = "forest-summon-btn";
      autoPassBtn.style.background = "#444";
      autoPassBtn.style.color = "#888";
      autoPassBtn.style.borderColor = "#666";
      autoPassBtn.style.padding = "8px 20px";
      autoPassBtn.style.fontSize = "14px";
      autoPassBtn.style.height = "auto";
      autoPassBtn.disabled = true;
      autoPassBtn.textContent = "自動放行中 (1.5秒)...";
      actionsDiv.appendChild(autoPassBtn);

      window.XLW_chainAutoPassTimeout = setTimeout(() => {
        ws.send(JSON.stringify({ action: "spell_chain_resolve" }));
        resolveLocalSpellChain();
      }, 1500);
    }
  }
}

function resolveLocalSpellChain() {
  hideSpellChainUI();
  
  if (window.XLW_chainAutoPassTimeout) {
    clearTimeout(window.XLW_chainAutoPassTimeout);
    window.XLW_chainAutoPassTimeout = null;
  }
  
  if (!spellChainStack || spellChainStack.length === 0) return;
  
  // 1. Work backwards from the top of the stack to determine which counter/spell resolves
  const resolved = new Array(spellChainStack.length).fill(true);
  for (let i = spellChainStack.length - 1; i >= 1; i--) {
    if (resolved[i]) {
      const counteringCard = spellChainStack[i] ? spellChainStack[i].card : null;
      const targetCard = spellChainStack[i - 1] ? spellChainStack[i - 1].card : null;
      
      if (counteringCard && targetCard) {
        const isTargetUnit = targetCard.type === "unit" || (targetCard.name && targetCard.name.includes("\u9b54\u6cd5\u70b8\u5f48\u5ba2")) || targetCard.id === "NEU-0025";
        const isCounterMagicOnly = (counteringCard.name && counteringCard.name.includes("\u9b54\u6cd5\u53cd\u5236")) || 
                                   (counteringCard.name && counteringCard.name.includes("\u7d42\u6975\u7121\u6548\u5316")) || 
                                   (counteringCard.name && counteringCard.name.includes("\u6cd5\u8853\u89e3\u6790")) || 
                                   (counteringCard.name && counteringCard.name.includes("\u6cd5\u8853\u4fdd\u8b77"));
                                   
        if (isTargetUnit && isCounterMagicOnly) {
          logBattle(`\u3010\u53cd\u5236\u7121\u6548\u3011${counteringCard.name} \u7121\u6cd5\u53cd\u5236\u55ae\u4f4d\u5361 ${targetCard.name} \u7684\u6548\u679c\uff01`);
        } else {
          // If card i resolves, it negates the card below it (i-1)
          resolved[i - 1] = false;
        }
      } else {
        resolved[i - 1] = false;
      }
    }
  }

  // 2. Resolve each card in the stack
  const S = spellChainStack[0];
  const isCountered = !resolved[0];

  // We process counters first (indices 1 to stack.length - 1)
  for (let i = 1; i < spellChainStack.length; i++) {
    const item = spellChainStack[i];
    const isItemCountered = !resolved[i];
    const cOwner = item.owner === "me" ? "player" : "enemy";

    if (item.card.name.includes("魔法炸彈客") || item.card.id === "NEU-0025") {
      if (isItemCountered) {
        if (item.owner === "me") {
          graveyard.push(item.card);
        } else {
          enemyGraveyard.push(item.card);
        }
      } else {
        // It resolves!
        // (a) Exile the magic bomber card itself
        exileCard(item.card, cOwner);
        // (b) Exile the top card of its owner's deck
        if (item.owner === "me") {
          if (deck.length > 0) {
            const topCard = deck.pop();
            exileCard(topCard, "player");
            const topName = (topCard && topCard.name) ? topCard.name : "未知卡牌";
            logBattle(`[魔法炸彈客] 效果：我方牌庫頂的 ${topName} 被除外。`);
          }
        } else {
          if (window.XLW_ENEMY.deck && window.XLW_ENEMY.deck.length > 0) {
            let topCard = window.XLW_ENEMY.deck.pop();
            if (!topCard) {
              topCard = { name: "對手卡牌", id: "UNKNOWN", type: "單位" };
            }
            exileCard(topCard, "enemy");
            const topName = topCard.name;
            logBattle(`[魔法炸彈客] 效果：對手牌庫頂的 ${topName} 被除外。`);
          }
        }
        // (c) Exile the card targeted/countered by it
        const targetItem = spellChainStack[i - 1];
        targetItem.wasExiledByBomb = true;
      }
    } else {
      // Normal counter spell
      if (item.owner === "me") {
        graveyard.push(item.card);
      } else {
        enemyGraveyard.push(item.card);
      }
    }
  }

  // 3. Resolve the initial spell (index 0)
  if (isCountered) {
    if (S.owner === "me") {
      if (S.wasExiledByBomb) {
        exileCard(S.card, "player");
        logBattle(`我方的魔法卡 ${S.card.name} 被對手【魔法炸彈客】除外了！`);
      } else {
        graveyard.push(S.card);
        logBattle(`我方的魔法卡 ${S.card.name} 被對手連鎖反制無效了！`);
      }
      if (window.XLW_pendingSpellResolve) {
        const resolve = window.XLW_pendingSpellResolve;
        window.XLW_pendingSpellResolve = null;
        resolve({ countered: true });
      }
    } else {
      if (S.wasExiledByBomb) {
        exileCard(S.card, "enemy");
        logBattle(`對手的魔法卡 ${S.card.name} 被我方【魔法炸彈客】除外了！`);
      } else {
        enemyGraveyard.push(S.card);
        logBattle(`對手的魔法卡 ${S.card.name} 被我方連鎖反制無效了！`);
      }
      if (window.XLW_pendingSpellResolve) {
        const resolve = window.XLW_pendingSpellResolve;
        window.XLW_pendingSpellResolve = null;
        resolve({ countered: true });
      }
    }
  } else {
    // Initial spell resolves successfully!
    if (S.owner === "me") {
      logBattle(`我方的魔法卡 ${S.card.name} 成功連鎖生效！`);
      if (window.XLW_pendingSpellResolve) {
        const resolve = window.XLW_pendingSpellResolve;
        window.XLW_pendingSpellResolve = null;
        resolve({ countered: false });
      }
    } else {
      enemyGraveyard.push(S.card);
      logBattle(`對手發動了魔法卡 ${S.card.name}：${S.card.effect_text || ""}`);
      if (window.XLW_pendingSpellResolve) {
        const resolve = window.XLW_pendingSpellResolve;
        window.XLW_pendingSpellResolve = null;
        resolve({ countered: false });
      }
    }
  }

  // Also clean up any other counter cards in the stack that were countered/exiled by a bomb
  for (let i = 1; i < spellChainStack.length; i++) {
    const item = spellChainStack[i];
    if (item.wasExiledByBomb) {
      const list = item.owner === "me" ? graveyard : enemyGraveyard;
      const idx = list.indexOf(item.card);
      if (idx >= 0) {
        list.splice(idx, 1);
      }
      exileCard(item.card, item.owner === "me" ? "player" : "enemy");
    }
  }

  spellChainStack = [];
  render();
  if (isMultiplayer && isMyTurn) {
    sendFullGameStateToOpponent();
  }
}

