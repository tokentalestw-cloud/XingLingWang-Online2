        shuffle(window.XLW_ENEMY.deck);
        logBattle(`✨ 對手 實習畫家 效果：從其牌庫將【${chosenCard.name}】加入手牌！`);
      } else {
        const gIdx = window.XLW_ENEMY.grave.indexOf(chosenCard);
        if (gIdx >= 0) window.XLW_ENEMY.grave.splice(gIdx, 1);
        logBattle(`✨ 對手 實習畫家 效果：從其墓地將【${chosenCard.name}】回收至手牌！`);
      }
      window.XLW_ENEMY.hand.push(chosenCard);
    } else {
      logBattle("對手 實習畫家 效果：對手牌庫與墓地中無任何顏料單位卡。");
    }
  }
  else if (card.id === "R-ART-0028" || card.name?.includes("最後的宵夜")) {
    const enemyGraveLast = window.XLW_ENEMY.grave.filter(c => c && c.type === "unit" && isLastCard(c));
    if (enemyGraveLast.length > 0) {
      const chosenCard = enemyGraveLast[Math.floor(Math.random() * enemyGraveLast.length)];
      const gIdx = window.XLW_ENEMY.grave.indexOf(chosenCard);
      if (gIdx >= 0) window.XLW_ENEMY.grave.splice(gIdx, 1);
      window.XLW_ENEMY.hand.push(chosenCard);
      logBattle(`✨ 對手 最後的宵夜 效果：將對手墓地中的【${chosenCard.name}】收回手牌！`);
    } else {
      logBattle("對手 最後的宵夜 效果：對手墓地無任何「最後的」單位卡，效果無法觸發。");
    }
  }
  else if (card.id === "R-ART-0027" || card.name?.includes("最後的下午茶")) {
    const lastUnitsInEnemyDeck = window.XLW_ENEMY.deck.filter(c => c && c.type === "unit" && isLastCard(c));
    if (lastUnitsInEnemyDeck.length > 0) {
      const chosenCard = lastUnitsInEnemyDeck[Math.floor(Math.random() * lastUnitsInEnemyDeck.length)];
      const dIdx = window.XLW_ENEMY.deck.indexOf(chosenCard);
      if (dIdx >= 0) window.XLW_ENEMY.deck.splice(dIdx, 1);
      window.XLW_ENEMY.hand.push(chosenCard);
      logBattle(`✨ 對手【最後的下午茶】效果：從其牌庫尋找【${chosenCard.name}】並加入手牌！`);
      shuffle(window.XLW_ENEMY.deck);
    } else {
      logBattle("對手【最後的下午茶】效果：對手牌庫無任何「最後的」單位卡。");
    }
  }
  else if (card.id === "R-ART-0029" || card.name?.includes("最後的中餐")) {
    let x = 0;
    for (const z of ["enemy_front", "enemy_back"]) {
      field[z].forEach(u => {
        if (u && u.card && isLastCard(u.card)) {
          x++;
        }
      });
    }
    logBattle(`對手【最後的中餐】效果：對手場上有 ${x} 個「最後的」單位，展示牌庫頂 ${x} 張卡牌！`);
    if (x > 0 && window.XLW_ENEMY.deck.length > 0) {
      const revealed = [];
      const count = Math.min(x, window.XLW_ENEMY.deck.length);
      for (let i = 0; i < count; i++) {
        revealed.push(window.XLW_ENEMY.deck.pop());
      }
      
      const lastUnits = [];
      const otherCards = [];
      revealed.forEach(c => {
        if (c && c.type === "unit" && isLastCard(c)) {
          lastUnits.push(c);
        } else {
          otherCards.push(c);
        }
      });
      
      for (const c of lastUnits) {
        let targetZone = null;
        let targetIdx = -1;
        for (const z of ["enemy_front", "enemy_back"]) {
          const idx = field[z].findIndex(u => !u);
          if (idx >= 0) {
            targetZone = z;
            targetIdx = idx;
            break;
          }
        }
        
        if (targetZone && targetIdx !== -1) {
          field[targetZone][targetIdx] = {
            card: c,
            tapped: false,
            attacking: false,
            target: null,
            summonedTurn: turn,
            summonedZone: targetZone
          };
          logBattle(`✨ 對手【最後的中餐】效果：特殊召喚【${c.name}】到對手場上！`);
