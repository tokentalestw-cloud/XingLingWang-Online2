    closeBtn.onclick = () => {
      overlay.remove();
      resolve({ success: false });
    };
    btnContainer.appendChild(closeBtn);
    content.appendChild(btnContainer);

    overlay.appendChild(content);
    document.body.appendChild(overlay);
  });
}

