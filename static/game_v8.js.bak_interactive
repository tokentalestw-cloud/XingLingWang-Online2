async function xlwCheckBananaMarquisMovement(isPlayerOwner) {
  const currentSide = isPlayerOwner ? "player" : "enemy";
  const targetSide = isPlayerOwner ? "enemy" : "player";
  
  const sourceZones = isPlayerOwner ? ["player_front", "player_back"] : ["enemy_front", "enemy_back"];
  const targetZones = isPlayerOwner ? ["enemy_front", "enemy_back"] : ["player_front", "player_back"];
  
  for (const sz of sourceZones) {
    if (!field[sz]) continue;
    for (let idx = 0; idx < field[sz].length; idx++) {
      const u = field[sz][idx];
      if (u && u.card && (u.card.id === "R-ART-0035" || u.card.name === "香蕉侯")) {
        let targetZone = null;
        let targetIdx = -1;
        
        for (const tz of targetZones) {
          if (!field[tz]) continue;
          for (let ti = 0; ti < field[tz].length; ti++) {
            if (!field[tz][ti]) {
              targetZone = tz;
              targetIdx = ti;
              break;
            }
          }
          if (targetZone) break;
        }
        
        if (targetZone && targetIdx !== -1) {
          const movingUnit = field[sz][idx];
          field[sz][idx] = null;
          
          movingUnit.attacking = false;
          movingUnit.target = null;
          movingUnit.summonedZone = targetZone;
          
          field[targetZone][targetIdx] = movingUnit;
          
          if (isPlayerOwner) {
            playerBonusScore += 1;
            logBattle(`✨ 【香蕉侯】效果發動：移動至對手場上 ${targetZone === "enemy_front" ? "前排" : "後排"}位置，我方獲得 +1★ 獎勵點數！`);
          } else {
            enemyBonusScore += 1;
            logBattle(`✨ 【香蕉侯】效果發動：移動至我方場上 ${targetZone === "player_front" ? "前排" : "後排"}位置，對手獲得 +1★ 獎勵點數！`);
          }
          
          if (isMultiplayer) {
            ws.send(JSON.stringify({
              action: "move_unit",
              fromZone: sz,
              fromIdx: idx,
              toZone: targetZone,
              toIdx: targetIdx
            }));
            sendFullGameStateToOpponent();
          }
          render();
          await sleep(600);
        } else {
          if (isPlayerOwner) {
            logBattle(`【香蕉侯】因對手場上已滿，移動失敗，無法獲得獎勵！`);
          } else {
            logBattle(`【香蕉侯】因我方場上已滿，移動失敗，對手無法獲得獎勵！`);
          }
        }
      }
    }
  }
}