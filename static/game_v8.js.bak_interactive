  }

  // 已確認起手換牌，但對手尚未就緒時，鎖定操作面板，避免發送提前結束回合指令
  if (phase === "起手換牌") {
    panel.innerHTML = `
      <button class="stable-action-btn end" style="background: #2b2525; color: #888; border-color: #443c3c; cursor: not-allowed; font-size: 15px;" disabled>等待對手確認換牌...</button>
    `;
    return;
