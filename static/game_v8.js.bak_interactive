async function xlwOnPlayerUnitTapped(zone, idx) {
  if (!zone || !zone.startsWith("player_")) return;
  window.XLW_turnTappedUnits = window.XLW_turnTappedUnits || new Set();
  const key = `${zone}:${idx}`;
  if (!window.XLW_turnTappedUnits.has(key)) {
    window.XLW_turnTappedUnits.add(key);
    logDebug(`【橫置追蹤】本回合新增橫置單位: ${key}，本回合累計橫置 ${window.XLW_turnTappedUnits.size} 個單位。`);
    await xlwCheckNegativeEnergyMeowUpgrade();
  }
}

async function xlwCheckNegativeEnergyMeowUpgrade() {
  const negativeMeow = playerExtraDeck.find(c => c && (c.id === "R-CAT-0046" || c.name === "負能量喵"));
  if (!negativeMeow) return;

  const tapCount = (window.XLW_turnTappedUnits ? window.XLW_turnTappedUnits.size : 0);
  if (tapCount < 3) return; // upgrade condition requires at least 2 other units tapped (so 3 total tapped this turn)

  let slotsWithGloomyMeow = [];
  for (const zone of ["player_front", "player_back"]) {
    field[zone].forEach((u, idx) => {
