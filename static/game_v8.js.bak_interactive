  try {
    allCards = await fetch("/api/cards?v=" + Date.now()).then(r => r.json());
    decks = await fetch("/api/decks?v=" + Date.now()).then(r => r.json());
    
    // 確保所有卡牌圖片有正確預設值
    allCards.forEach(c => {
