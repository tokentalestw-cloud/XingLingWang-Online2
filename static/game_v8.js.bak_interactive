// 小旅人按鈕觸發
function triggerLittleTraveler(e) {
  if (e) e.stopPropagation();
  if (isMultiplayer && !isMyTurn) {
    setStatus("對手回合中，請稍候！");
    return;
  }
  const can = (phase === "召喚階段" && !normalSummonUsed) || (phase === "戰術佈陣" && !tacticalSummonUsed);
  if (!can) {
    setStatus("目前階段無法召喚小旅人。");
    return;
  }
  clearModes();
  tributeWaitingPosition = true; // 借用位置等待狀態
  selectedHandForSummon = "TRAVELER";
  setStatus("【小旅人】請點選我方一個空格進行召喚（前排優先）。");
  render();
}

// 魔法卡點擊發動
// 魔法卡點擊發動
async function castSpell(handIndex) {
  if (isMultiplayer && !isMyTurn) {
    setStatus("對手回合中，請稍候！");
    return;
  }
  const card = hand[handIndex];
  if (!card || card.type !== "magic") return;

  const isPureCounter = card.name && (card.name.includes("魔法反制") || card.name.includes("終極無效化") || card.name.includes("法術解析") || card.name.includes("星空") || card.id === "ART-0020");
  if (isPureCounter) {
    if (card.id === "ART-0020" || card.name.includes("星空")) {
      setStatus("【提示】反制魔法卡無法直接打出，必須在對手召喚單位時發動進行反制。");
    } else {
      setStatus("【提示】反制魔法卡無法直接打出，必須在對手使用魔法卡時進行反制。");
    }
    showModal(card);
    return;
  }

  // 1. Target and cost pre-checks before casting/chaining to prevent card loss or dead chains
  if (card.name.includes("逗喵棒") || card.id === "R-CAT-0040") {
    let hasMeowUnit = false;
    for (const z of ["player_front", "player_back"]) {
      if (field[z].some(u => u && (u.card?.faction === "喵喵賊" || u.card?.race === "喵喵賊" || u.card?.id?.includes("CAT") || u.card?.id?.includes("cat")))) {
        hasMeowUnit = true;
      }
    }
    if (!hasMeowUnit) {
      setStatus("場上無我方喵喵賊單位可以指定！");
      return;
    }
  } else if (card.name.includes("恐懼凝視")) {
    let hasEnemyUnit = false;
    for (const zone of ["enemy_front", "enemy_back"]) {
      if (field[zone].some(u => u !== null)) hasEnemyUnit = true;
    }
    if (!hasEnemyUnit) {
      setStatus("對方場上無單位可禁錮！");
      return;
    }
  } else if (card.name.includes("山羊術")) {
    let hasAnyUnit = false;
    for (const zone of ["player_front", "player_back", "enemy_front", "enemy_back"]) {
      if (field[zone].some(u => u !== null)) hasAnyUnit = true;
    }
    if (!hasAnyUnit) {
      setStatus("場上無單位可變成山羊！");
      return;
    }
  } else if (card.name.includes("魔抗鐵拳")) {
    let hasAnyUnit = false;
    for (const zone of ["player_front", "player_back", "enemy_front", "enemy_back"]) {
      if (field[zone].some(u => u !== null)) hasAnyUnit = true;
    }
    if (!hasAnyUnit) {
      setStatus("場上無單位可施加魔抗鐵拳！");
      return;
    }
  } else if (card.name?.includes("法力回收壺") || card.id === "R-NMG-0023") {
    const spellsInGrave = graveyard.filter(c => c && c.type === "magic");
    if (spellsInGrave.length === 0) {
      setStatus("墓地無魔法卡可回收！");
      return;
    }
  } else if (card.id === "R-0RC-0044" || card.id === "R-ORC-0034" || card.id === "R-ORC-0054" || card.id === "R-ORC-0056" || card.id === "SR-ORC-0043" ||
             card.name?.includes("符咒帽") || card.name?.includes("菜刀") || card.name?.includes("狼牙棒") || card.name?.includes("弓箭") || card.name?.includes("戰斧牛排")) {
    let hasOrc = false;
    for (const z of ["player_front", "player_back"]) {
      if (field[z].some(u => u && (u.card?.faction === "獸人" || u.card?.race === "獸人" || u.card?.id?.includes("ORC") || u.card?.id?.includes("0RC") || u.card?.id?.includes("ROC")))) {
        hasOrc = true;
      }
    }
    if (!hasOrc) {
      setStatus("場上無獸人單位可裝備！");
      return;
    }
  }

  const isTempEquipMagic = 
    card.name.includes("削弱藥水") || card.id?.includes("0003") ||
    card.name.includes("振奮藥水") || card.id?.includes("0002") ||
    card.name.includes("塗毒") || card.id?.includes("0004") ||
    card.name.includes("睡眠反擊拳") || card.id?.includes("0025");

  if (isTempEquipMagic) {
    if (phase !== "防守階段") {
      setStatus(`【${card.name}】只能在防守階段使用！`);
      return;
    }
    let hasAnyUnit = false;
    for (const zone of ["player_front", "player_back", "enemy_front", "enemy_back"]) {
      if (field[zone].some(u => u !== null)) hasAnyUnit = true;
    }
    if (!hasAnyUnit) {
      setStatus(`場上沒有任何單位可以施放【${card.name}】！`);
      return;
    }
  }

  // Remove card from hand immediately
  hand.splice(handIndex, 1);

  // 對手反制判定 (在 multiplayer 模式下，或在單機 VS AI 模式下)
  if (!isMultiplayer) {
    const hasBomb = window.XLW_ENEMY.hand && window.XLW_ENEMY.hand.some(c => c && (c.name.includes("魔法炸彈客") || c.id === "NEU-0025"));
    const hasCounter = window.XLW_ENEMY.hand && window.XLW_ENEMY.hand.some(c => c && (c.name.includes("魔法反制") || c.name.includes("法術保護") || c.name.includes("終極無效化") || c.name.includes("法術解析") || c.id === "SSR-NMG-0019" || c.id === "NMG-0019"));
    
    if (hasBomb && window.XLW_ENEMY.deck && window.XLW_ENEMY.deck.length > 0 && Math.random() < 0.45) {
      const bombCard = window.XLW_ENEMY.hand.find(c => c && (c.name.includes("魔法炸彈客") || c.id === "NEU-0025"));
      const bIdx = window.XLW_ENEMY.hand.indexOf(bombCard);
      window.XLW_ENEMY.hand.splice(bIdx, 1);
      const exiledLibCard = window.XLW_ENEMY.deck.pop();
      const exiledLibName = (exiledLibCard && exiledLibCard.name) ? exiledLibCard.name : "未知卡牌";
      logBattle(`對手從手牌除外了 ${bombCard.name}，並將對手牌庫頂的 ${exiledLibName} 一併除外，無效化了我方的魔法卡 ${card.name}！`);
      exileCard(bombCard, "enemy");
      exileCard(exiledLibCard, "enemy");
      
      exileCard(card, "player");
      clearModes();
      render();
      return;
    } else if (hasCounter && Math.random() < 0.45) {
      const counterCard = window.XLW_ENEMY.hand.find(c => c && (c.name.includes("魔法反制") || c.name.includes("法術保護") || c.name.includes("終極無效化") || c.name.includes("法術解析")));
      const cIdx = window.XLW_ENEMY.hand.indexOf(counterCard);
      window.XLW_ENEMY.hand.splice(cIdx, 1);
      window.XLW_ENEMY.grave.push(counterCard);
      logBattle(`對手從手牌發動了 ${counterCard.name}，無效化了我方的魔法卡 ${card.name}！`);
      
      graveyard.push(card);
      clearModes();
      render();
      return;
    }
  } else {
    // Multiplayer Countering Chain
    spellChainStack = [{ card: card, owner: "me" }];
    showSpellChainUI(spellChainStack);
    
    ws.send(JSON.stringify({
      action: "spell_chain_start",
      card: card
    }));
    
    promptNextChainAction();
    
    const response = await new Promise(resolve => {
      window.XLW_pendingSpellResolve = resolve;
    });
    
    if (response.countered) {
      clearModes();
      render();
      return;
    }
  }

  const text = card.effect_text || "";
  
  // 逗喵棒：使你場上1個喵喵賊單位被轉正，並可使其移動至你場上任意位置
  if (card.name.includes("逗喵棒") || card.id === "R-CAT-0040") {
    let meowUnits = [];
    for (const z of ["player_front", "player_back"]) {
      field[z].forEach((u, i) => {
        if (u && (u.card?.faction === "喵喵賊" || u.card?.race === "喵喵賊" || u.card?.id?.includes("CAT") || u.card?.id?.includes("cat"))) {
          meowUnits.push({ zone: z, idx: i, unit: u });
        }
      });
    }
    if (meowUnits.length > 0) {
      const choices = meowUnits.map((item, idx) => ({
        text: `${item.zone === "player_front" ? "前排" : "後排"}${item.idx + 1} 的 ${item.unit.card.name}`,
        value: idx
      }));
      const chosenIdx = await showXLWChoiceModal("逗喵棒 效果發動", "選擇我方一個喵喵賊單位以轉正及移動：", choices);
      if (chosenIdx !== null && chosenIdx !== undefined) {
        const targetItem = meowUnits[chosenIdx];
        targetItem.unit.tapped = false;
        logBattle(`✨ 逗喵棒 效果：使我方 ${targetItem.unit.card.name} 轉正！`);

        let emptySlots = [];
        for (const z of ["player_front", "player_back"]) {
          for (let i = 0; i < 5; i++) {
            if (!field[z][i]) emptySlots.push({ zone: z, idx: i });
          }
        }

        let teasingStickMoved = false;
        let targetToZone = null;
        let targetToIdx = -1;

        if (emptySlots.length > 0) {
          const moveConfirm = await showXLWConfirm("逗喵棒 移動效果", "是否要將該單位移動至我方場上其他位置？");
          if (moveConfirm) {
            window.XLW_teasingStickMoveActive = true;
            window.XLW_teasingStickFromZone = targetItem.zone;
            window.XLW_teasingStickFromIdx = targetItem.idx;
            setStatus(`【逗喵棒】請點選我方場上一個空白格子進行移動！`);
            render();
            const res = await new Promise(r => { window.XLW_teasingStickResolve = r; });
            teasingStickMoved = res.moved;
            if (teasingStickMoved) {
              targetToZone = res.toZone;
              targetToIdx = res.toIdx;
            }
          }
        }
        
        if (isMultiplayer) {
          ws.send(JSON.stringify({
            action: "teasing_stick_resolved",
            targetZone: targetItem.zone,
            targetIdx: targetItem.idx,
            fromZone: teasingStickMoved ? targetItem.zone : null,
            toZone: teasingStickMoved ? targetToZone : null,
            toIdx: teasingStickMoved ? targetToIdx : null
          }));
        }
        
        window.XLW_teasingStickMoveActive = false;
        window.XLW_teasingStickFromZone = null;
        window.XLW_teasingStickFromIdx = -1;
        render();
      } else {
        // Canceled choosing a unit
        hand.splice(handIndex, 0, card); // Return card to hand
        render();
        return;
      }
    } else {
      setStatus("場上無我方喵喵賊單位可以指定！");
      hand.splice(handIndex, 0, card);
      render();
      return;
    }
  }
  // 1. 恐懼凝視：使對手場上1單位受到禁錮
  else if (card.name.includes("恐懼凝視")) {
    let hasEnemyUnit = false;
    for (const zone of ["enemy_front", "enemy_back"]) {
      if (field[zone].some(u => u !== null)) hasEnemyUnit = true;
    }
    if (hasEnemyUnit) {
      window.XLW_confiningSpellActive = true;
      setStatus("【恐懼凝視】請點選對手場上一個單位使其受到禁錮！");
      render();
      await new Promise(r => { window.XLW_confinementResolve = r; });
    } else {
      setStatus("對方場上無單位可禁錮！");
      return;
    }
  }
  // 2. 山羊術：使場上1單位變為山羊
  else if (card.name.includes("山羊術")) {
    let hasAnyUnit = false;
    for (const zone of ["player_front", "player_back", "enemy_front", "enemy_back"]) {
      if (field[zone].some(u => u !== null)) hasAnyUnit = true;
    }
    if (hasAnyUnit) {
      window.XLW_goatSpellActive = true;
      window.XLW_goatSpellCard = card;
      setStatus("【山羊術】請點選場上一個單位將其變為山羊！");
      render();
      await new Promise(r => { window.XLW_goatResolve = r; });
    } else {
      setStatus("場上無單位可變成山羊！");
      return;
    }
  }
  // 3. 魔抗鐵拳：+1/-1攻擊力，且獲得魔法免疫效果
  else if (card.name.includes("魔抗鐵拳")) {
    let hasAnyUnit = false;
    for (const zone of ["player_front", "player_back", "enemy_front", "enemy_back"]) {
      if (field[zone].some(u => u !== null)) hasAnyUnit = true;
    }
    if (hasAnyUnit) {
      window.XLW_resistIronFistActive = true;
      setStatus("【魔抗鐵拳】請點選場上一個單位施加魔抗鐵拳！");
      render();
      await new Promise(r => { window.XLW_resistIronFistResolve = r; });
    } else {
      setStatus("場上無單位可附加魔抗鐵拳！");
      return;
    }
  }
  // 4. 恐怖的井 / 持久魔法卡放置到場地區
  else if (card.name.includes("恐怖的井") || card.magic_type === "場地" || card.name.includes("場地") || text.includes("結束階段時")) {
    const playerField = $("playerField");
    if (playerField) {
      if (playerField.dataset.card) {
        graveyard.push(JSON.parse(playerField.dataset.card));
      }
      playerField.dataset.card = JSON.stringify(card);
      logBattle(`設置魔法卡：${card.name}`);
    }
  } else if (card.name?.includes("法力回收壺") || card.id === "R-NMG-0023") {
    const spellsInGrave = graveyard.filter(c => c && c.type === "magic");
    if (spellsInGrave.length > 0) {
      const choices = spellsInGrave.map((c, i) => ({ text: `${c.name} (墓地)`, value: i }));
      const chosenIdx = await showXLWChoiceModal("法力回收壺 效果：選擇一張墓地魔法卡回手", "選擇魔法卡：", choices);
      if (chosenIdx !== null && chosenIdx !== undefined) {
        const chosenSpell = spellsInGrave[chosenIdx];
        const gIdx = graveyard.indexOf(chosenSpell);
        if (gIdx >= 0) graveyard.splice(gIdx, 1);
        hand.push(chosenSpell);
        logBattle(`✨ 法力回收壺 效果：將墓地魔法卡 ${chosenSpell.name} 回收至手牌！`);
      }
    } else {
      setStatus("墓地中無魔法卡可回收！");
      return;
    }
  } else if (card.name?.includes("力場保護") || card.id === "NMG-0040") {
    while (true) {
      const opt = await showXLWChoiceModal(
        "力場保護 效果選擇",
        "請選擇要發動的效果：",
        [
          { text: "🛡️ 讓我方已在場上的一張場地卡具備破壞抗性", value: "protect_field" },
          { text: "🎴 抽一張牌", value: "draw_card" }
        ]
      );
      if (opt === "protect_field") {
        const playerField = $("playerField");
        if (playerField && playerField.dataset.card) {
          const fCard = JSON.parse(playerField.dataset.card);
          fCard.indestructible = true;
          playerField.dataset.card = JSON.stringify(fCard);
          logBattle(`✨ 力場保護 效果：使我方場上的場地卡【${fCard.name}】具備破壞抗性！`);
          if (isMultiplayer) {
            ws.send(JSON.stringify({ action: "field_indestructible" }));
          }
          break;
        } else {
          await showXLWConfirm("力場保護", "我方場上目前沒有場地卡，無法發動此效果！請選擇「抽一張牌」！", "確定");
        }
      } else if (opt === "draw_card") {
        draw(1);
        logBattle("✨ 力場保護 效果：我方抽 1 張牌。");
        break;
      }
    }
  } else if (card.name?.includes("法術保護") || card.id === "SSR-NMG-0019" || card.id === "NMG-0019") {
    const opt = await showXLWChoiceModal(
      "法術保護 效果選擇",
      "請選擇要發動的效果：",
      [
        { text: "🛡️ 使我方 1 單位獲得法術保護（不會被敵方魔法卡選為目標）", value: "protect_unit" },
        { text: "⚡ 使敵方 1 魔法卡無效化（⚠️ 須在對手打出當下反制使用）", value: "negate_magic" }
      ]
    );
    if (opt === "negate_magic") {
      await showXLWConfirm("法術保護", "【提示】無效化效果必須在對手打出魔法卡的當下，於反制提示框中發動。目前無法直接打出。", "確定");
      hand.splice(handIndex, 0, card); // 加回手牌
      render();
      return;
    } else if (opt === "protect_unit") {
      let hasMyUnit = false;
      for (const z of ["player_front", "player_back"]) {
        if (field[z].some(u => u !== null)) hasMyUnit = true;
      }
      if (!hasMyUnit) {
        await showXLWConfirm("法術保護", "我方場上目前沒有任何單位可以施加法術保護！", "確定");
        hand.splice(handIndex, 0, card); // 加回手牌
        render();
        return;
      }
      
      window.XLW_equipSpellActive = true;
      window.XLW_equipSpellCard = { ...card, name: "法術保護-護盾" };
      setStatus("【法術保護】請點選我方場上一個單位以賦予法術保護（對魔抗性）！");
      render();
      await new Promise(r => { window.XLW_equipSpellResolve = r; });
    }
  } else if (card.id === "R-0RC-0044" || card.id === "R-ORC-0034" || card.id === "R-ORC-0054" || card.id === "R-ORC-0056" || card.id === "SR-ORC-0043" || card.id === "R-ORC-0025" ||
             card.name?.includes("符咒帽") || card.name?.includes("菜刀") || card.name?.includes("狼牙棒") || card.name?.includes("弓箭") || card.name?.includes("戰斧牛排") || card.name?.includes("迴旋飛斧")) {
    let hasOrc = false;
    for (const z of ["player_front", "player_back"]) {
      if (field[z].some(u => u && (u.card?.faction === "獸人" || u.card?.race === "獸人" || u.card?.id?.includes("ORC") || u.card?.id?.includes("0RC") || u.card?.id?.includes("ROC")))) {
        hasOrc = true;
      }
    }
    if (!hasOrc) {
      setStatus("場上無我方獸人單位可以裝備此卡！");
      return;
    }

    if (card.name?.includes("戰斧牛排") || card.id === "SR-ORC-0043") {
      let equipCards = [];
      graveyard.forEach((c, idx) => {
        if (c && c.type === "magic" && (c.name.includes("帽") || c.name.includes("菜刀") || c.name.includes("狼牙棒") || c.name.includes("弓") || c.name.includes("牛排") || c.name.includes("斧"))) {
          equipCards.push({ source: "graveyard", index: idx, card: c });
        }
      });
      for (const z of ["player_front", "player_back"]) {
        for (let i = 0; i < 5; i++) {
          const u = field[z][i];
          if (u && u.equipments && u.equipments.length > 0) {
            u.equipments.forEach((eqName, eqIdx) => {
              const isTempMagic = ["削弱藥水", "振奮藥水", "塗毒", "睡眠反擊拳"].some(x => eqName.includes(x));
              if (!isTempMagic) {
                equipCards.push({ source: "field", zone: z, slotIdx: i, eqIdx: eqIdx, name: eqName });
              }
            });
          }
        }
      }

      if (equipCards.length < 2) {
        setStatus("我方場上與墓地裝備卡不足 2 張，無法除外以發動戰斧牛排！");
        return;
      }

      const proceed = await showXLWConfirm("戰斧牛排 額外代價", `發動戰斧牛排需要除外我方場上/墓地共 2 張裝備卡，系統將自動為您除外以下裝備卡：\n${equipCards.slice(0, 2).map(e => e.card ? e.card.name : e.name).join("、")}。是否確認？`);
      if (!proceed) {
        return;
      }

      const toRemove = equipCards.slice(0, 2);
      toRemove.forEach(item => {
        if (item.source === "graveyard") {
          const idx = graveyard.indexOf(item.card);
          if (idx !== -1) {
            graveyard.splice(idx, 1);
          }
          exileCard(item.card, "player");
          logBattle(`[戰斧牛排 代價] 除外了墓地裝備卡：${item.card.name}`);
        } else {
          const u = field[item.zone][item.slotIdx];
          if (u && u.equipments) {
            const idx = u.equipments.indexOf(item.name);
            if (idx !== -1) {
              u.equipments.splice(idx, 1);
            }
            const cardObj = allCards.find(c => c && c.name === item.name) || { name: item.name, type: "magic" };
            exileCard(cardObj, "player");
            logBattle(`[戰斧牛排 代價] 除外了場上 ${u.card.name} 附著的裝備：${item.name}`);
          }
        }
      });
    }

    window.XLW_equipSpellActive = true;
    window.XLW_equipSpellCard = card;
    setStatus(`【${card.name}】請點選我方一個獸人單位進行裝備！`);
    render();
    await new Promise(r => { window.XLW_equipSpellResolve = r; });
  } else {
    // 普通魔法效果
    if (card.id === "ORC-0018" || card.name?.includes("賞金")) {
      let hasEnemyUnit = false;
      for (const z of ["enemy_front", "enemy_back"]) {
        if (field[z].some(u => u !== null)) hasEnemyUnit = true;
      }
      if (!hasEnemyUnit) {
        setStatus("敵方場上目前沒有任何單位可以施加賞金！");
        return;
      }
      window.XLW_tempEquipSpellActive = true;
      window.XLW_tempEquipSpellCard = card;
      setStatus("【賞金】請點選敵方場上一個單位以施加賞金狀態！");
      render();
      await new Promise(r => { window.XLW_tempEquipSpellResolve = r; });
    } else if (isTempEquipMagic) {
      window.XLW_tempEquipSpellActive = true;
      window.XLW_tempEquipSpellCard = card;
      let promptText = `【${card.name}】`;
      if (card.name.includes("削弱藥水")) {
        promptText += "請選擇場上一個單位，賦予 -3 攻擊力直到本回合結束。";
      } else if (card.name.includes("振奮藥水")) {
        promptText += "請選擇場上一個單位，賦予 +3 攻擊力直到下個回合結束。";
      } else if (card.name.includes("塗毒")) {
        promptText += "請選擇場上一個單位，賦予劇毒。";
      } else if (card.name.includes("睡眠反擊拳")) {
        promptText += "請選擇我方場上一個防守單位（橫置單位），賦予 +3 攻擊力直到本回合結束。";
      }
      setStatus(promptText);
      render();
      await new Promise(r => { window.XLW_tempEquipSpellResolve = r; });
    } else if (card.id === "R-ART-0047" || card.name?.includes("最後的麵包與酒")) {
      const choices = [];
      const hasYeshuInDeck = deck.some(c => c && (c.id === "SR-ART-0026" || c.name?.includes("和平使者 耶叔")));
      if (hasYeshuInDeck) {
        choices.push({ text: "從牌庫檢索【和平使者 耶叔】加入手牌並重洗牌庫", value: "search_yeshu" });
      } else {
        choices.push({ text: "從牌庫檢索【和平使者 耶叔】（牌庫中無此卡，不可選）", value: "disabled_search", disabled: true });
      }

      const lastUnitsInHand = hand.filter(c => c && c.type === "unit" && isLastCard(c));
      if (lastUnitsInHand.length > 0) {
        choices.push({ text: "從手牌特殊召喚 1 個免祭品【最後的】單位", value: "special_summon_last" });
      } else {
        choices.push({ text: "從手牌特殊召喚 1 個免祭品【最後的】單位（手牌中無此類單位，不可選）", value: "disabled_summon", disabled: true });
      }
      
      choices.push({ text: "取消發動魔法卡", value: "cancel" });

      const chosen = await showXLWChoiceModal("最後的麵包與酒 效果選擇", "請選擇要執行的效果：", choices);
      if (chosen === null || chosen === undefined || chosen === "cancel" || chosen === "disabled_search" || chosen === "disabled_summon") {
        hand.push(card);
        logBattle("取消發動【最後的麵包與酒】。");
        clearModes();
        render();
        return;
      }

      if (chosen === "search_yeshu") {
        const yIdx = deck.findIndex(c => c && (c.id === "SR-ART-0026" || c.name?.includes("和平使者 耶叔")));
        if (yIdx >= 0) {
          const yeshuCard = deck.splice(yIdx, 1)[0];
          hand.push(yeshuCard);
          logBattle(`✨ 最後的麵包與酒 效果：從牌庫檢索【${yeshuCard.name}】並加入手牌，重新洗牌！`);
          shuffle(deck);
        } else {
          logBattle("最後的麵包與酒 效果：無法檢索【和平使者 耶叔】（牌庫中已無此卡）。");
        }
      } else if (chosen === "special_summon_last") {
        await new Promise(resolve => setTimeout(resolve, 500));
        const summonChoices = lastUnitsInHand.map((c, idx) => ({ text: `${c.name} (星級: ${c.stars || c.star || 0})`, value: idx }));
        const chosenSummonIdx = await showXLWChoiceModal("最後的麵包與酒：特殊召喚", "請選擇手牌中的【最後的】單位特殊召喚到場上：", summonChoices);
        if (chosenSummonIdx !== null && chosenSummonIdx !== undefined) {
          const chosenCard = lastUnitsInHand[chosenSummonIdx];
          
          let emptySlots = [];
          for (const z of ["player_front", "player_back"]) {
            for (let i = 0; i < 5; i++) {
              if (!field[z][i]) emptySlots.push({ zone: z, idx: i });
            }
          }
          if (emptySlots.length > 0) {
            const slotChoices = emptySlots.map((s, idx) => ({ text: `${s.zone === "player_front" ? "前排" : "後排"}${s.idx + 1}`, value: idx }));
            const chosenSlotIdx = await showXLWChoiceModal("最後的麵包與酒：選擇召喚格子", "請選擇召喚的目標格子（免祭品）：", slotChoices);
            if (chosenSlotIdx !== null && chosenSlotIdx !== undefined) {
              const targetSlot = emptySlots[chosenSlotIdx];
              const handIdx = hand.indexOf(chosenCard);
              if (handIdx >= 0) {
                selectedHandForSummon = handIdx;
                window.XLW_bypassNormalSummonLimit = true;
                await performSummonToSlot(targetSlot.zone, targetSlot.idx);
                logBattle(`✨ 最後的麵包與酒 效果：免祭品特殊召喚手牌 of 【${chosenCard.name}】到我方 ${targetSlot.zone === "player_front" ? "前排" : "後排"}${targetSlot.idx + 1}！`);
              }
            } else {
              logBattle("未選擇格子，取消特殊召喚。");
            }
          } else {
            logBattle("我方場上已滿，無法特殊召喚。");
          }
        } else {
          logBattle("未選擇特殊召喚的單位。");
        }
      }
      graveyard.push(card);
    } else if (text.includes("抽2張")) {
      draw(2);
      logBattle(`發動魔法 ${card.name}：抽 2 張牌`);
    } else if (text.includes("抽1張")) {
      draw(1);
      logBattle(`發動魔法 ${card.name}：抽 1 張牌`);
    } else if (text.includes("加分") || text.includes("額外分")) {
      playerBonusScore += 1;
      logBattle(`發動魔法 ${card.name}：我方額外加 1 分`);
    } else {
      logBattle(`發動魔法 ${card.name}`);
    }
    graveyard.push(card);
  }

  clearModes();
  render();
}

// 點手牌的獻祭怪進入獻祭模式
// 點手牌的獻祭怪進入獻祭模式
async function startTributeSummon(handIndex) {
  const card = hand[handIndex];
  const targetCost = getCardTributeCost(card);
  if (!card || card.type !== "unit" || targetCost <= 0) return;

  if (phase === "戰術佈陣") {
    setStatus("戰術佈陣階段只能召喚免祭品單位或小旅人，不能進行獻祭召喚。");
    return;
  }

  if (normalSummonUsed) {
    setStatus("本回合召喚階段已進行過普通/獻祭召喚。");
    return;
  }

  // 十八呎大人 特殊手牌折抵祭品效果
  if (card.name.includes("十八呎") || card.id === "VLG_011") {
    const yokaiInHand = hand.filter((c, idx) => idx !== handIndex && c && (c.faction === "妖怪村莊" || c.id?.includes("VLG")));
    if (yokaiInHand.length > 0) {
      const confirm = await showXLWConfirm(
        "十八呎大人 特殊獻祭",
        `手牌中偵測到其他妖怪村莊單位，是否從手牌棄置 1 張作為 2 個祭品？`,
        "是，棄置手牌",
        "否，使用場上單位"
      );
      if (confirm) {
        const choices = yokaiInHand.map(c => ({ text: `${c.name} (${c.id})`, value: hand.indexOf(c) }));
        const discardIdx = await showXLWChoiceModal("選擇折抵祭品", "請點選要作為祭品送入墓地的手牌卡片：", choices);
        if (discardIdx !== null && discardIdx !== undefined) {
          const discarded = hand[discardIdx];
          hand.splice(discardIdx, 1);
          graveyard.push(discarded);
          logBattle(`十八呎大人 效果：棄置手牌中的 ${discarded.name} 作為 2 個祭品。`);
          
          selectedTributes.push({ key: `hand_discard_dummy1_${Date.now()}`, zone: "dummy", idx: -1 });
          selectedTributes.push({ key: `hand_discard_dummy2_${Date.now()}`, zone: "dummy", idx: -1 });
          
          const curVal = countSelectedTributesValue(selectedTributes, card);
          if (curVal >= targetCost) {
            const newHandIndex = hand.indexOf(card);
            if (newHandIndex >= 0) {
              selectedHandForTribute = newHandIndex;
              selectedTributeCard = card;
              confirmTribute();
              return;
            }
          }
        }
      }
    }
  }

  // 流浪畫家 特殊手牌折抵祭品效果
  const isArt = card.faction === "藝術品" || card.id?.includes("ART") || card.race?.includes("藝術品");
  const isNonHumanoid = card.art_subtype !== "人型";
  let hasVagabondPainter = false;
  for (const z of ["player_front", "player_back"]) {
    for (let i = 0; i < 5; i++) {
      const u = field[z][i];
      if (u && u.card && (u.card.id === "R-ART-0033" || u.card.name?.includes("流浪畫家"))) {
        hasVagabondPainter = true;
        break;
      }
    }
    if (hasVagabondPainter) break;
  }

  const pigmentInHand = hand.filter((c, idx) => idx !== handIndex && c && isPigmentCard(c));
  const hasUnusedVagabond = window.XLW_vagabondPainterUsedTurn !== turn;

  if (isArt && isNonHumanoid && hasVagabondPainter && hasUnusedVagabond && pigmentInHand.length > 0) {
    const confirm = await showXLWConfirm(
      "流浪畫家 效果發動",
      `場上有【流浪畫家】，是否將手牌中 1 張顏料單位作為此非人型藝術品單位【${card.name}】的 1 個祭品？（每回合限一次）`,
      "是，使用手牌顏料",
      "否，使用場上單位"
    );
    if (confirm) {
      const choices = pigmentInHand.map(c => ({ text: `${c.name} (${c.id})`, value: hand.indexOf(c) }));
      const discardIdx = await showXLWChoiceModal("選擇顏料作為祭品", "請點選要送入墓地的手牌顏料：", choices);
      if (discardIdx !== null && discardIdx !== undefined) {
        const discarded = hand[discardIdx];
        hand.splice(discardIdx, 1);
        graveyard.push(discarded);
        logBattle(`流浪畫家 效果：棄置手牌中的 ${discarded.name} 作為 1 個祭品。`);
        window.XLW_vagabondPainterUsedTurn = turn;
        
        selectedTributes.push({ key: `vagabond_dummy_${Date.now()}`, zone: "dummy", idx: -1 });
        
        const curVal = countSelectedTributesValue(selectedTributes, card);
        if (curVal >= targetCost) {
          const newHandIndex = hand.indexOf(card);
          if (newHandIndex >= 0) {
            selectedHandForTribute = newHandIndex;
            selectedTributeCard = card;
            confirmTribute();
            return;
          }
        }
      }
    }
  }

  // 重新計算當前卡牌在手牌中的 index 避免被上述 discard 效果改變了 index
  handIndex = hand.indexOf(card);
  if (handIndex < 0) return;

  clearModes();
  selectedHandForTribute = handIndex;
  selectedTributeCard = card;
  logDebug(`【獻祭啟動】卡牌: ${card.name}, 需要祭品數: ${targetCost}, 手牌位置: ${handIndex}`);
  setStatus(`【獻祭召喚】${card.name} 需要 ${targetCost} 個祭品。請點選我方場上單位作為祭品。`);
  render();
}

function toggleTributeSelection(zone, idx) {
  if (selectedHandForTribute === null) return;
  if (!zone.startsWith("player_")) return;

  const unit = field[zone][idx];
  if (!unit) return;

  // 不可獻祭判定
  const c = unit.card || unit;
  if (c.id === "R-ART-0035" || c.name?.includes("香蕉侯")) {
    setStatus(`【獻祭失敗】${c.name} 無法被獻祭！`);
    return;
  }
  if (isUnitConfined(zone, idx)) {
    setStatus(`【獻祭失敗】${c.name} 處於禁錮或不可獻祭狀態！`);
    return;
  }

  const key = `${zone}:${idx}`;
  const existIdx = selectedTributes.findIndex(t => t.key === key);
  const card = hand[selectedHandForTribute];
  const targetCost = getCardTributeCost(card);

  const isGraffiti = card && (card.id === "R-ART-0046" || card.name?.includes("牆壁上的塗鴉"));
  if (isGraffiti && !isPigmentCard(c)) {
    setStatus("【獻祭失敗】牆壁上的塗鴉 只能使用顏料單位作為祭品！");
    return;
  }

  if (existIdx >= 0) {
    selectedTributes.splice(existIdx, 1);
    const curVal = countSelectedTributesValue(selectedTributes, card);
    logDebug(`【祭品取消】取消選取: ${key}, 當前祭品值: ${curVal}/${targetCost}`);
  } else {
    const curVal = countSelectedTributesValue(selectedTributes, card);
    if (curVal >= targetCost) {
      setStatus(`祭品已選滿（需求 ${targetCost}）。若要更換，請先點擊已選祭品取消。`);
      return;
    }
    selectedTributes.push({ zone, idx, key });
    const newVal = countSelectedTributesValue(selectedTributes, card);
    logDebug(`【祭品追加】追加選取: ${key}, 當前祭品值: ${newVal}/${targetCost}`);
  }

  const finalVal = countSelectedTributesValue(selectedTributes, card);
  if (finalVal >= targetCost) {
    setStatus(`祭品已選滿。請點擊「確認獻祭」按鈕。`);
  } else {
    setStatus(`【獻祭召喚】已選祭品點數 ${finalVal}/${targetCost}。`);
  }
  render();
}

function confirmTribute() {
  if (selectedHandForTribute === null) return;
  const card = hand[selectedHandForTribute];
  const targetCost = getCardTributeCost(card);
  const selectedVal = countSelectedTributesValue(selectedTributes, card);
  if (selectedVal < targetCost) {
    setStatus("祭品數量不足！");
    return;
  }

  // 祭品送墓前觸發效果
  const executeTributeEffects = async () => {
    for (const t of selectedTributes) {
      if (t.zone === "dummy") continue; 
      const unit = field[t.zone][t.idx];
      if (unit && unit.card) {
        // (a) 晴天娃娃: 破壞場地牌
        if (unit.card.name.includes("晴天娃娃")) {
          const choices = [];
          if ($("playerField").dataset.card) choices.push({ text: "破壞我方場地牌", value: "player" });
          if ($("enemyField").dataset.card) choices.push({ text: "破壞敵方場地牌", value: "enemy" });
          if (choices.length > 0) {
            const chosen = await showXLWChoiceModal("晴天娃娃 獻祭效果", "請選擇要破壞的場地牌：", choices);
            if (chosen === "player") {
              const fCard = JSON.parse($("playerField").dataset.card);
              const has貞美子 = field["player_front"].concat(field["player_back"]).some(u => u && (u.card?.id === "R-VLG-0010" || u.card?.name?.includes("貞美子")));
              if (fCard && fCard.name.includes("恐怖的井") && has貞美子) {
                logBattle("晴天娃娃 效果：因我方場上有【貞美子】，【恐怖的井】獲得免疫保護，破壞無效！");
              } else if (fCard && fCard.indestructible) {
                logBattle("晴天娃娃 效果：因【力場保護】效果，我方場地牌免疫破壞！");
              } else {
                delete $("playerField").dataset.card;
                graveyard.push(fCard);
                logBattle("晴天娃娃 效果：我方場地牌被破壞。");
              }
            } else if (chosen === "enemy") {
              const fCard = JSON.parse($("enemyField").dataset.card);
              const has貞美子 = field["enemy_front"].concat(field["enemy_back"]).some(u => u && (u.card?.id === "R-VLG-0010" || u.card?.name?.includes("貞美子")));
              if (fCard && fCard.name.includes("恐怖的井") && has貞美子) {
                logBattle("晴天娃娃 效果：因對手場上有【貞美子】，對手【恐怖的井】獲得免疫保護，破壞無效！");
              } else if (fCard && fCard.indestructible) {
                logBattle("晴天娃娃 效果：因【力場保護】效果，敵方場地牌免疫破壞！");
              } else {
                delete $("enemyField").dataset.card;
                window.XLW_ENEMY.grave.push(fCard);
                logBattle("晴天娃娃 效果：敵方場地牌被破壞。");
              }
            }
          }
        }
        // (b) 嘴裂的女孩: 破壞前方第一個敵方單位
        if (unit.card.name.includes("嘴裂的女孩")) {
          const col = t.idx;
          let targetUnit = field["enemy_front"][col] || field["enemy_back"][col];
          if (targetUnit) {
            const targetZone = field["enemy_front"][col] ? "enemy_front" : "enemy_back";
            logBattle(`嘴裂的女孩 效果：破壞其前方第一格的敵方單位 ${targetUnit.card.name}！`);
            await destroyUnit(targetZone, col, "enemy");
          }
        }
        // (c) 河童: 放置在對手場地
        if (unit.card.name.includes("河童")) {
          const confirm = await showXLWConfirm("河童 獻祭效果", "是否將河童作為被動效果放置於對手場地？");
          if (confirm) {
            const enemyField = $("enemyField");
            if (enemyField) {
              if (enemyField.dataset.card) {
                window.XLW_ENEMY.grave.push(JSON.parse(enemyField.dataset.card));
              }
              enemyField.dataset.card = JSON.stringify(unit.card);
              logBattle(`河童 效果：河童被放置在對手的場地中！對手前排進攻單位攻擊力 -1。`);
            }
          }
        }
        // (d) 瓶子長長: 移動敵方單位
        if (unit.card.name.includes("瓶子長長")) {
          let hasEnemyUnit = false;
          for (const zone of ["enemy_front", "enemy_back"]) {
            if (field[zone].some(u => u !== null)) hasEnemyUnit = true;
          }
          if (hasEnemyUnit) {
            setStatus("【瓶子長長 效果】請點選敵方場上一個單位進行移動！");
            window.XLW_bottleMovingActive = true;
            render();
            await new Promise(r => { window.XLW_bottleResolve = r; });
          }
        }

        // (e) 九尾妖狐: 破壞敵方一整條戰線上的所有單位
        if (unit.card.id === "R-VLG-0004" || unit.card.name.includes("九尾妖狐")) {
          const choices = [
            { text: "戰線 1 (直列 1)", value: 0 },
            { text: "戰線 2 (直列 2)", value: 1 },
            { text: "戰線 3 (直列 3)", value: 2 },
            { text: "戰線 4 (直列 4)", value: 3 },
            { text: "戰線 5 (直列 5)", value: 4 }
          ];
          const isPlayer = t.zone.startsWith("player_");
          if (isPlayer) {
            const laneIdx = await showXLWChoiceModal("九尾妖狐 獻祭效果發動", "請選擇要破壞的對手星星戰線（該直列的所有敵方單位）：", choices);
            if (laneIdx !== null && laneIdx !== undefined) {
              logBattle(`九尾妖狐 效果：破壞對手第 ${laneIdx + 1} 條戰線上的所有單位！`);
              const dests = [];
              for (const ez of ["enemy_front", "enemy_back"]) {
                if (field[ez][laneIdx]) {
                  dests.push(destroyUnit(ez, laneIdx, "enemy"));
                  if (isMultiplayer) {
                    ws.send(JSON.stringify({
                      action: "destroy_unit",
                      zone: ez,
                      idx: laneIdx
                    }));
                  }
                }
              }
              if (dests.length > 0) {
                await Promise.all(dests);
              }
            }
          } else {
            let occupiedLanes = [];
            for (let i = 0; i < 5; i++) {
              if (field["player_front"][i] || field["player_back"][i]) {
                occupiedLanes.push(i);
              }
            }
            const laneIdx = occupiedLanes.length > 0 ? occupiedLanes[Math.floor(Math.random() * occupiedLanes.length)] : Math.floor(Math.random() * 5);
            logBattle(`對手九尾妖狐 效果：破壞我方第 ${laneIdx + 1} 條戰線上的所有單位！`);
            const dests = [];
            for (const pz of ["player_front", "player_back"]) {
              if (field[pz][laneIdx]) {
                dests.push(destroyUnit(pz, laneIdx, "player"));
              }
            }
            if (dests.length > 0) {
              await Promise.all(dests);
            }
          }
        }

        // (f) 藍小鬼棒子: 抽 1 張牌
        if (unit.card.id === "R-VLG-0007" || unit.card.name.includes("藍小鬼棒子")) {
          const isPlayer = t.zone.startsWith("player_");
          if (isPlayer) {
            draw(1);
            logBattle("藍小鬼棒子 效果：被獻祭，我方抽 1 張牌。");
          } else {
            if (window.XLW_ENEMY.deck.length) {
              window.XLW_ENEMY.hand.push(window.XLW_ENEMY.deck.pop());
            }
            logBattle("對手藍小鬼棒子 效果：被獻祭，對手抽 1 張牌。");
          }
        }

        // (g) 紅小鬼棒子: 將墓地中另一張妖怪村莊單位回收到手牌
        if (unit.card.id === "R-VLG-0008" || unit.card.name.includes("紅小鬼棒子")) {
          const isPlayer = t.zone.startsWith("player_");
          if (isPlayer) {
            const yokaiInGrave = graveyard.filter(c => c && c.type === "unit" && (c.faction === "妖怪村莊" || c.id?.includes("VLG")));
            if (yokaiInGrave.length > 0) {
              const choices = yokaiInGrave.map((c, i) => ({ text: `${c.name} (${c.id})`, value: i }));
              const chosenIdx = await showXLWChoiceModal("紅小鬼棒子 效果發動", "選擇回到手牌 the 妖怪村莊單位：", choices);
              if (chosenIdx !== null && chosenIdx !== undefined) {
                const targetCard = yokaiInGrave[chosenIdx];
                const gIdx = graveyard.indexOf(targetCard);
                if (gIdx >= 0) {
                  graveyard.splice(gIdx, 1);
                  hand.push(targetCard);
                  logBattle(`紅小鬼棒子 效果：將墓地中的 ${targetCard.name} 回收到手牌。`);
                }
              }
            } else {
              logBattle("紅小鬼棒子 效果：墓地中無其他妖怪村莊單位，回收無效。");
            }
          } else {
            const yokaiInGrave = window.XLW_ENEMY.grave.filter(c => c && c.type === "unit" && (c.faction === "妖怪村莊" || c.id?.includes("VLG")));
            if (yokaiInGrave.length > 0) {
              const targetCard = yokaiInGrave[Math.floor(Math.random() * yokaiInGrave.length)];
              const gIdx = window.XLW_ENEMY.grave.indexOf(targetCard);
              if (gIdx >= 0) {
                window.XLW_ENEMY.grave.splice(gIdx, 1);
                window.XLW_ENEMY.hand.push(targetCard);
                logBattle(`對手紅小鬼棒子 效果：將其墓地中的 ${targetCard.name} 回收到手牌。`);
              }
            }
          }
        }

        // (h) 獨眼小僧: 查看對手牌庫頂，選置牌庫底
        if (unit.card.id === "R-VLG-0023" || unit.card.name.includes("獨眼小僧")) {
          const isPlayer = t.zone.startsWith("player_");
          if (isPlayer) {
            const enemyDeck = window.XLW_ENEMY.deck;
            if (enemyDeck && enemyDeck.length > 0) {
              const topCard = enemyDeck[enemyDeck.length - 1];
              const action = await showXLWChoiceModal(
                "獨眼小僧 效果發動 (查看對手牌庫頂)",
                `對手牌庫頂卡牌為：【${topCard.name}】(${topCard.id})。請選擇處理方式：`,
                [
                  { text: "維持放置在牌庫頂", value: "top" },
                  { text: "放置到牌庫底", value: "bottom" }
                ]
              );
              if (action === "bottom") {
                enemyDeck.pop();
                enemyDeck.unshift(topCard);
                logBattle(`獨眼小僧 效果：將對手牌庫頂的 ${topCard.name} 置於其牌庫底。`);
              } else {
                logBattle(`獨眼小僧 效果：對手牌庫頂的 ${topCard.name} 保持不動。`);
              }
            } else {
              logBattle("獨眼小僧 效果：對手牌庫已空。");
            }
          } else {
            if (deck.length > 0) {
              const topCard = deck[deck.length - 1];
              if (Math.random() < 0.5) {
                deck.pop();
                deck.unshift(topCard);
                logBattle(`對手獨眼小僧 效果：將我方牌庫頂的 ${topCard.name} 置於我方牌庫底。`);
              } else {
                logBattle(`對手獨眼小僧 效果：我方牌庫頂的 ${topCard.name} 保持不動。`);
              }
            }
          }
        }

        // (i) 獨眼大僧: 查看對手手牌，選 1 張置牌庫底
        if (unit.card.id === "R-VLG-0024" || unit.card.name.includes("獨眼大僧")) {
          const isPlayer = t.zone.startsWith("player_");
          if (isPlayer) {
            const enemyHand = window.XLW_ENEMY.hand;
            if (enemyHand && enemyHand.length > 0) {
              const choices = enemyHand.map((c, i) => ({ text: `${c.name} (${c.id})`, value: i }));
              const chosenIdx = await showXLWChoiceModal("獨眼大僧 效果發動 (查看並棄置敵方手牌)", "請選擇對手 1 張手牌置於對手牌庫底：", choices);
              if (chosenIdx !== null && chosenIdx !== undefined) {
                const targetCard = enemyHand[chosenIdx];
                enemyHand.splice(chosenIdx, 1);
                window.XLW_ENEMY.deck.unshift(targetCard);
                logBattle(`獨眼大僧 效果：查看對手手牌，並將對手的 ${targetCard.name} 置於其牌庫底。`);
              }
            } else {
              logBattle("獨眼大僧 效果：對手手牌為空。");
            }
          } else {
            if (hand.length > 0) {
              const chosenIdx = Math.floor(Math.random() * hand.length);
              const targetCard = hand[chosenIdx];
              hand.splice(chosenIdx, 1);
              deck.unshift(targetCard);
              logBattle(`對手獨眼大僧 效果：對手查看我方手牌，並將我方的 ${targetCard.name} 置於我方牌庫底。`);
            }
          }
        }

        // (j) 藍大鬼棒子: 棄置我方至多 3 手牌
        if (unit.card.id === "R-VLG-0025" || unit.card.name.includes("藍大鬼棒子")) {
          const isPlayer = t.zone.startsWith("player_");
          if (isPlayer) {
            if (hand.length > 0) {
              let discardedCount = 0;
              while (discardedCount < 3 && hand.length > 0) {
                const choices = [
                  { text: "結束棄牌", value: -1 },
                  ...hand.map((c, idx) => ({ text: `${c.name} (${c.id})`, value: idx }))
                ];
                const chosenIdx = await showXLWChoiceModal(`藍大鬼棒子 效果發動 (已棄置 ${discardedCount}/3 張)`, "選擇一張要棄置的手牌卡牌：", choices);
                if (chosenIdx === -1 || chosenIdx === null || chosenIdx === undefined) {
                  break;
                }
                const discarded = hand[chosenIdx];
                hand.splice(chosenIdx, 1);
                graveyard.push(discarded);
                logBattle(`藍大鬼棒子 效果：手牌 ${discarded.name} 被棄置。`);
                discardedCount++;
              }
            } else {
              logBattle("藍大鬼棒子 效果：我方無手牌可棄。");
            }
          } else {
            if (window.XLW_ENEMY.hand.length > 0) {
              const discardNum = Math.min(window.XLW_ENEMY.hand.length, Math.floor(Math.random() * 2));
              for (let i = 0; i < discardNum; i++) {
                const idx = Math.floor(Math.random() * window.XLW_ENEMY.hand.length);
                const discarded = window.XLW_ENEMY.hand.splice(idx, 1)[0];
                window.XLW_ENEMY.grave.push(discarded);
                logBattle(`對手藍大鬼棒子 效果：棄置其手牌 ${discarded.name}。`);
              }
            }
          }
        }

        // (k) 紅大鬼棒子: 除外對手墓地 1 牌
        if (unit.card.id === "R-VLG-0026" || unit.card.name.includes("紅大鬼棒子")) {
          const isPlayer = t.zone.startsWith("player_");
          if (isPlayer) {
            const enemyGrave = window.XLW_ENEMY.grave;
            if (enemyGrave && enemyGrave.length > 0) {
              const choices = enemyGrave.map((c, i) => ({ text: `${c.name} (${c.type === "unit" ? "單位" : "魔法"})`, value: i }));
              const chosenIdx = await showXLWChoiceModal("紅大鬼棒子 效果發動 (除外對手墓地卡牌)", "選擇對手墓地中要除外的卡牌：", choices);
              if (chosenIdx !== null && chosenIdx !== undefined) {
                const targetCard = enemyGrave[chosenIdx];
                enemyGrave.splice(chosenIdx, 1);
                exileCard(targetCard, "enemy");
                logBattle(`紅大鬼棒子 效果：除外了對手墓地中的卡牌 ${targetCard.name}。`);
              }
            } else {
              logBattle("紅大鬼棒子 效果：對手墓地為空。");
            }
          } else {
            if (graveyard.length > 0) {
              const chosenIdx = Math.floor(Math.random() * graveyard.length);
              const targetCard = graveyard[chosenIdx];
              graveyard.splice(chosenIdx, 1);
              exileCard(targetCard, "player");
              logBattle(`對手紅大鬼棒子 效果：對手將我方墓地中的 ${targetCard.name} 除外。`);
            }
          }
        }
      }
    }
  };

  executeTributeEffects().then(async () => {
    // 記錄被獻祭的祭品位置，供聯網召喚同步清除
    window.XLW_lastTributes = selectedTributes.map(t => ({ zone: t.zone, idx: t.idx }));

    selectedTributes.forEach(t => {
      if (t.zone === "dummy") return;
      const unit = field[t.zone][t.idx];
      if (unit) {
        // 先處理裝備卡送入墓地
        if (unit.equipments && unit.equipments.length > 0) {
          unit.equipments.forEach(eqName => {
            const isTempMagic = ["削弱藥水", "振奮藥水", "塗毒", "睡眠反擊拳"].some(x => eqName.includes(x));
            if (isTempMagic) return;
            const cardObj = allCards.find(c => c && c.name === eqName) || { name: eqName, type: "magic" };
            const cloned = structuredClone(cardObj);
            cloned.type = "magic";
            graveyard.push(cloned);
            logBattle(`✨ 裝備卡 ${cloned.name} 隨著單位被獻祭進入我方墓地。`);
          });
          unit.equipments = [];
        }

        if (unit.card.name === "大耳賊" || unit.card.id === "NEU-0064") {
    if (zone.startsWith("player_")) {
      enemyBonusScore += 2;
      logBattle(`💥 大耳賊 被戰鬥破壞：對手額外獎勵 +2 ★！`);
    } else {
      playerBonusScore += 2;
      logBattle(`💥 大耳賊 被戰鬥破壞：我方額外獎勵 +2 ★！`);
    }
  }

  if (unit.card.name.includes("小旅人") || unit.card.id === "TOKEN_TRAVELER") {
          logBattle(`✨ ${unit.card.name} 作為祭品被獻祭，直接返回森林。`);
        } else {
          graveyard.push(unit.card);
        }
        field[t.zone][t.idx] = null;
      }
    });

    const targetIdx = selectedHandForTribute;
    tributeWaitingPosition = true;
    selectedHandForSummon = targetIdx;
    selectedHandForTribute = null;
    selectedTributes = [];

    setStatus(`祭品已送入墓地！請點選我方空格召喚 ${card.name}（前排優先）。`);
    render();

    // 牆壁妖怪獻祭連召效果
    const wallIdx = hand.findIndex(c => c && c.name.includes("牆壁妖怪"));
    const hasEmptySlot = ["player_front", "player_back"].some(zone => field[zone].some(u => u === null));
    if (wallIdx >= 0 && hasEmptySlot) {
      setTimeout(async () => {
        const confirm = await showXLWConfirm("牆壁妖怪 效果發動", "偵測到場上有單位被獻祭，是否從手牌額外特殊召喚 牆壁妖怪？（不佔用常規召喚次數）");
        if (confirm) {
          window.XLW_bypassNormalSummonLimit = true;
          window.XLW_bypassTurnCheck = true;
          selectedHandForSummon = wallIdx;
          setStatus("【牆壁妖怪 召喚】請點選我方一個空格進行特殊召喚！");
          render();
          await new Promise(r => { window.XLW_summonPlacementResolve = r; });
          window.XLW_bypassTurnCheck = false;
        }
      }, 500);
    }

    // 雨傘妖怪自召效果
    const hasUmbrellaInGrave = graveyard.some(c => c && c.name.includes("雨傘妖怪"));
    if (hasUmbrellaInGrave && hasEmptySlot) {
      setTimeout(async () => {
        const confirm = await showXLWConfirm("雨傘妖怪 效果發動", "偵測到墓地中有雨傘妖怪且場上有單位被獻祭，是否將其自墓地特殊召喚？");
        if (confirm) {
          const graveIdx = graveyard.findIndex(c => c && c.name.includes("雨傘妖怪"));
          const card = graveyard[graveIdx];
          graveyard.splice(graveIdx, 1);
          window.XLW_bypassNormalSummonLimit = true;
          window.XLW_bypassTurnCheck = true;
          selectedHandForSummon = "GRAVEYARD_UMBRELLA";
          window.XLW_tempGraveCard = card;
          setStatus("【雨傘妖怪 復活】請點選我方一個空格進行特殊召喚！");
          render();
          await new Promise(r => { window.XLW_summonPlacementResolve = r; });
          window.XLW_bypassTurnCheck = false;
        }
      }, 800);
    }
  });
}

// 實行手牌召喚/小旅人召喚至格子上
async function performSummonToSlot(zone, idx) {
  logDebug(`【點選放置】目標格子: ${zone}:${idx + 1}`);
  // 獻祭召喚與位置放置之強大對象參考匹配與 Fallback 恢復機制
  if (tributeWaitingPosition && selectedTributeCard !== null) {
    const isGraveyardSummon = (selectedHandForSummon === "GRAVEYARD_UMBRELLA" || 
                               selectedHandForSummon === "GRAVEYARD_WELL" || 
                               selectedHandForSummon === "GRAVEYARD_GHOST_MEOW");
    let isDifferentHandCard = false;
    if (typeof selectedHandForSummon === "number" || (typeof selectedHandForSummon === "string" && !isNaN(selectedHandForSummon))) {
      const currentCard = hand[Number(selectedHandForSummon)];
      if (currentCard && currentCard.id !== selectedTributeCard.id) {
        isDifferentHandCard = true;
      }
    }
    
    if (!isGraveyardSummon && !isDifferentHandCard) {
      const idxInHand = hand.indexOf(selectedTributeCard);
      if (idxInHand >= 0) {
        selectedHandForSummon = idxInHand;
        logDebug(`【對象匹配】實體匹配成功！手牌 Index: ${selectedHandForSummon}`);
      } else {
        const matchIdx = hand.findIndex(c => c && c.id === selectedTributeCard.id);
        if (matchIdx >= 0) {
          selectedHandForSummon = matchIdx;
          logDebug(`【對象匹配】ID 匹配成功！手牌 Index: ${selectedHandForSummon}`);
        } else {
          const foundIdx = hand.findIndex(c => c && getCardTributeCost(c) > 0);
          if (foundIdx >= 0) {
            selectedHandForSummon = foundIdx;
            logDebug(`【對象匹配】兜底 Fallback 匹配成功！手牌 Index: ${selectedHandForSummon}`);
          } else {
            logDebug("【放置終止】祭品已送墓，但在手牌中找不到任何獻祭卡牌！");
            return;
          }
        }
      }
    }
  }

  if (selectedHandForSummon === null) {
    logDebug("【放置終止】當前 selectedHandForSummon 為 null！");
    return;
  }

  if (isMultiplayer && !isMyTurn && !window.XLW_bypassTurnCheck) {
    setStatus("對手回合中，請稍候！");
    logDebug("【放置終止】非我方回合！");
    return;
  }

  const canSum = window.XLW_bypassNormalSummonLimit ||
                 (phase === "召喚階段" && !normalSummonUsed) || 
                 (phase === "戰術佈陣" && !tacticalSummonUsed);
  if (!canSum) {
    setStatus("本回合已進行過單位召喚。");
    logDebug(`【放置終止】本回合召喚次數已用盡！(normalSummonUsed: ${normalSummonUsed})`);
    clearModes();
    render();
    return;
  }

  let card = null;
  try {

  if (selectedHandForSummon === "TRAVELER") {
    // 召喚小旅人
    field[zone][idx] = {
      card: structuredClone(LITTLE_TRAVELER),
      tapped: false,
      attacking: false,
      target: null,
      summonedTurn: turn,
      summonedZone: zone
    };
    if (phase === "召喚階段" && !window.XLW_bypassTurnCheck) normalSummonUsed = true;
    if (phase === "戰術佈陣" && !window.XLW_bypassTurnCheck) tacticalSummonUsed = true;
    logBattle(`從森林召喚小旅人到 ${zone.includes("front") ? "前排" : "後排"}${idx + 1}`);
    playTravelerSummonAnimation("#playerForest", zone, idx);
  } else {
    // 召喚手牌
    const isTributeSummon = (tributeWaitingPosition && selectedTributeCard !== null);
    let handIndex = Number(selectedHandForSummon);
    
    card = null;
    if (selectedHandForSummon === "GRAVEYARD_UMBRELLA" || selectedHandForSummon === "GRAVEYARD_WELL" || selectedHandForSummon === "GRAVEYARD_GHOST_MEOW") {
      card = window.XLW_tempGraveCard;
    } else {
      if (handIndex < 0 || handIndex >= hand.length || !hand[handIndex]) {
        if (tributeWaitingPosition) {
          const foundIdx = hand.findIndex(c => c && getCardTributeCost(c) > 0);
          if (foundIdx >= 0) {
            handIndex = foundIdx;
          }
        }
      }
      if (handIndex >= 0 && hand[handIndex]) {
        card = hand[handIndex];
      }
    }

    if (!card) {
      setStatus("找不到手牌中的卡牌，請點選重新召喚。");
      return;
    }

    const isLyingOrc = card.id === "R-ORC-0031" || card.name?.includes("躺平獸人");
    field[zone][idx] = {
      card: structuredClone(card),
      tapped: isLyingOrc,
      attacking: false,
      target: null,
      summonedTurn: turn,
      summonedZone: zone
    };

    const isExtraSum = (selectedHandForSummon === "GRAVEYARD_UMBRELLA" || 
                        selectedHandForSummon === "GRAVEYARD_WELL" || 
                        selectedHandForSummon === "GRAVEYARD_GHOST_MEOW" ||
                        window.XLW_bypassNormalSummonLimit);
    if (isExtraSum && zone.startsWith("player_")) {
      window.XLW_turnExtraSummonsCount = (window.XLW_turnExtraSummonsCount || 0) + 1;
      logDebug(`【額外召喚追蹤】我方進行了額外召喚！本回合已額外召喚 ${window.XLW_turnExtraSummonsCount} 個單位。`);
    }

    if (selectedHandForSummon === "GRAVEYARD_UMBRELLA" || selectedHandForSummon === "GRAVEYARD_WELL" || selectedHandForSummon === "GRAVEYARD_GHOST_MEOW") {
      window.XLW_tempGraveCard = null;
      window.XLW_bypassNormalSummonLimit = false;
      logBattle(`特殊召喚墓地單位 ${card.name} 到 ${zone.includes("front") ? "前排" : "後排"}${idx + 1}`);
    } else {
      hand.splice(handIndex, 1);
      if (window.XLW_bypassNormalSummonLimit) {
        window.XLW_bypassNormalSummonLimit = false;
        logDebug(`【連動額外召喚】成功！不佔用本回合常規召喚額度。`);
        
        const isPlayer = zone.startsWith("player_");
        const checkZonePrefix = isPlayer ? "player_" : "enemy_";
        const prOnField = field[checkZonePrefix + "front"].concat(field[checkZonePrefix + "back"]).some(u => {
          return u && u.card && (u.card.id === "CAT_005" || u.card.id === "R-CAT-0041" || u.card.name.includes("公關姐姐喵"));
        });
        if (prOnField) {
          if (isPlayer) {
            playerBonusScore += 1;
            logBattle(`✨ 公關姐姐喵 效果：我方進行額外召喚單位，我方額外獎勵 +1 分！`);
          } else {
            enemyBonusScore += 1;
            logBattle(`✨ 公關姐姐喵 效果：對手進行額外召喚單位，對手額外獎勵 +1 分！`);
          }
          renderScore();
        }
      } else {
        if (phase === "召喚階段") normalSummonUsed = true;
        if (phase === "戰術佈陣") tacticalSummonUsed = true;
      }
      logDebug(`【召喚成功】卡牌: ${card.name} 已成功放置於 ${zone}:${idx + 1}！手牌扣減成功。`);
      logBattle(`召喚單位 ${card.name} 到 ${zone.includes("front") ? "前排" : "後排"}${idx + 1}`);
    }
    
    let immediateEffectNegated = false;
    let summonMessageSent = false;

    if (isMultiplayer) {
      if (!window.XLW_isFoodBallSummoning) {
        summonMessageSent = true;
        const isFromHand = (selectedHandForSummon !== "TRAVELER" &&
                            selectedHandForSummon !== "GRAVEYARD_UMBRELLA" &&
                            selectedHandForSummon !== "GRAVEYARD_WELL" &&
                            selectedHandForSummon !== "GRAVEYARD_GHOST_MEOW");
        ws.send(JSON.stringify({
          action: "summon",
          card: field[zone][idx].card,
          zone: zone,
          idx: idx,
          fromHand: isFromHand,
          tributes: window.XLW_lastTributes || []
        }));
        window.XLW_lastTributes = null;

        const response = await new Promise(resolve => {
          window.XLW_pendingSummonCounterResolve = resolve;
        });

        if (response.countered) {
          immediateEffectNegated = true;
          logBattle(`對手發動了手牌中的【星空】！召喚的【${card.name}】被破壞，效果無效。`);
          await destroyUnit(zone, idx, "player", false);
          render();
        }
      }
    } else {
      const oppHand = window.XLW_ENEMY?.hand || [];
      const hasStarry = oppHand.some(c => c && (c.id === "ART-0020" || c.name?.includes("星空")));
      if (hasStarry) {
        const sIdx = oppHand.findIndex(c => c && (c.id === "ART-0020" || c.name?.includes("星空")));
        const sCard = oppHand.splice(sIdx, 1)[0];
        window.XLW_ENEMY.grave.push(sCard);
        enemyGraveyard = window.XLW_ENEMY.grave;

        immediateEffectNegated = true;
        logBattle(`✨ 對手 AI 發動了手牌中的【星空】！`);
        await destroyUnit(zone, idx, "player", false);
        render();
      }
    }

    if (!immediateEffectNegated) {
      // 立即特殊效果：雪女、座敷童子、燈籠小鬼、恐怖錄影帶、八岐大蛇
      if (zone.startsWith("player_")) {
      if (card.id === "ART-0007" || card.name?.includes("兩位陌生人")) {
